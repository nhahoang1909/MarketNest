      <div class="card-body">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
          <div class="flex items-center gap-3">
            <span class="mn-mono text-sm font-semibold text-ink-700">#MN-2024-004</span>
            <span class="badge badge-red">Da huy</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-ink-400">10/03/2024</span>
            <span class="mn-mono text-sm font-bold text-ink-700 line-through opacity-60">450.000 VND</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div
