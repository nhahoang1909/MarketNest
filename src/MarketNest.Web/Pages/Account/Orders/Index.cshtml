              </div>
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-ink-700">Green Garden Shop</p>
              <p class="text-xs text-ink-400">2 san pham</p>
            </div>
          </div>
          <a href="@AppRoutes.Account.Orders/e5f6a7b8-c9d0-1234-efab-345678901234" class="btn-ghost btn-sm">
