@page "/account/orders"
@model MarketNest.Web.Pages.Account.Orders.IndexModel
@{
  ViewData["Title"] = "Don hang cua toi";
}

<section class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-8" x-data="{ activeFilter: 'all' }">

  <!-- Title -->
  <h1 class="mn-h4 mb-6">Don hang cua toi</h1>

  <!-- Filter pills -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button @@click="activeFilter = 'all'" :class="activeFilter === 'all' ? 'mn-chip mn-chip-active' : 'mn-chip'">
      Tat ca
    </button>
    <button @@click="activeFilter = 'processing'"
            :class="activeFilter === 'processing' ? 'mn-chip mn-chip-active' : 'mn-chip'">
      Dang xu ly
    </button>
    <button @@click="activeFilter = 'shipped'"
            :class="activeFilter === 'shipped' ? 'mn-chip mn-chip-active' : 'mn-chip'">
      Dang giao
    </button>
    <button @@click="activeFilter = 'delivered'"
            :class="activeFilter === 'delivered' ? 'mn-chip mn-chip-active' : 'mn-chip'">
      Da giao
    </button>
    <button @@click="activeFilter = 'cancelled'"
            :class="activeFilter === 'cancelled' ? 'mn-chip mn-chip-active' : 'mn-chip'">
      Da huy
    </button>
  </div>

  <!-- Order cards -->
  <div class="space-y-4">

    <!-- Order 1: Delivered -->
    <div class="card" x-show="activeFilter === 'all' || activeFilter === 'delivered'" x-transition>
      <div class="card-body">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
          <div class="flex items-center gap-3">
            <span class="mn-mono text-sm font-semibold text-ink-700">#MN-2024-001</span>
            <span class="badge badge-green">Da giao</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-ink-400">15/03/2024</span>
            <span class="mn-mono text-sm font-bold text-ink-700">1.250.000 VND</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-ink-700">Handmade Store</p>
              <p class="text-xs text-ink-400">2 san pham</p>
            </div>
          </div>
          <a href="@AppRoutes.Account.Orders/a1b2c3d4-e5f6-7890-abcd-ef1234567890" class="btn-ghost btn-sm">
            Chi tiet
          </a>
        </div>
      </div>
    </div>

    <!-- Order 2: Shipped -->
    <div class="card" x-show="activeFilter === 'all' || activeFilter === 'shipped'" x-transition>
      <div class="card-body">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
          <div class="flex items-center gap-3">
            <span class="mn-mono text-sm font-semibold text-ink-700">#MN-2024-002</span>
            <span class="badge badge-blue">Dang giao</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-ink-400">18/03/2024</span>
            <span class="mn-mono text-sm font-bold text-ink-700">890.000 VND</span>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-ink-700">Eco Living VN</p>
              <p class="text-xs text-ink-400">1 san pham</p>
            </div>
          </div>
          <a href="@AppRoutes.Account.Orders/b2c3d4e5-f6a7-8901-bcde-f12345678901" class="btn-ghost btn-sm">
            Chi tiet
          </a>
        </div>
      </div>
    </div>

    <!-- Order 3: Processing -->
    <div class="card" x-show="activeFilter === 'all' || activeFilter === 'processing'" x-transition>
