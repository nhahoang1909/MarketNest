        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
              <div
                class="w-[60px] h-[60px] rounded-xl bg-cream-200 border-2 border-surface flex items-center justify-center text-xs text-ink-400">
                SP
              </div>
            </div>
            <div>
              <p class="text-sm font-medium text-ink-700">Vintage Corner</p>
