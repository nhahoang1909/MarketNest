@page "/admin/config"
@model MarketNest.Web.Pages.Admin.Config.IndexModel
@{
  Layout = "_LayoutAdmin";
  ViewData["Title"] = "System Config";
}

<div class="flex gap-5 items-start">
  <!-- Config sub-sidebar -->
  <partial name="Navigation/_ConfigSubSidebar"/>

  <!-- Main config content -->
  <div class="flex-1 min-w-0 space-y-5">
    <!-- Header -->
    <div>
      <p class="text-[10px] font-bold uppercase tracking-[0.12em] text-slate-400">— Configuration</p>
      <h1 class="text-3xl font-bold text-slate-900 mt-1" style="font-family:@AppConstants.Fonts.DisplayShort">System Config</h1>
      <p class="text-[13px] text-slate-500 mt-2 max-w-xl">
        Manage reference data, business rules, and platform settings. Select a category from the sidebar to get started.
      </p>
    </div>

    <!-- Quick links grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      @{
        var cards = new[]
        {
          new { Title = "Countries", Desc = "ISO countries available across the marketplace. Controls shipping zones and locale mapping.", Route = AppRoutes.Admin.ConfigCountry, Icon = "M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" },
          new { Title = "Genders", Desc = "Identity options surfaced in account profiles, seller onboarding, and analytics segments.", Route = AppRoutes.Admin.ConfigGender, Icon = "M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07" },
          new { Title = "Telephone codes", Desc = "International dialing codes and validation patterns used by phone-input fields.", Route = AppRoutes.Admin.ConfigPhoneCode, Icon = "M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106" },
          new { Title = "Nationalities", Desc = "Nationality options separate from Country. Used in identity verification forms.", Route = AppRoutes.Admin.ConfigNationality, Icon = "M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732" },
          new { Title = "Product categories", Desc = "Top-level merchandise taxonomy. Sellers pick from this list when creating products.", Route = AppRoutes.Admin.ConfigProductCategory, Icon = "M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33" },
          new { Title = "Commission rates", Desc = "Platform take rate by category or seller tier. Highest matching tier wins.", Route = AppRoutes.Admin.ConfigCommission, Icon = "M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75" }
        };
      }

      @foreach (var card in cards)
      {
        <a href="@card.Route"
           class="group flex items-center gap-4 p-5 rounded-2xl bg-white border border-slate-200/80
                  hover:border-slate-300 hover:shadow-sm transition-all duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background:#f1f0eb;">
            <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="@card.Icon"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <h3 class="text-sm font-bold text-slate-900">@card.Title</h3>
              <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full"
                    style="background:@AppConstants.Colors.AccentBg; color:@AppConstants.Colors.AccentDarker;">
                Read-only
              </span>
            </div>
            <p class="text-xs text-slate-500 mt-1 line-clamp-2">@card.Desc</p>
          </div>
          <svg class="w-4 h-4 text-slate-300 group-hover:text-slate-500 transition-colors shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
          </svg>
        </a>
      }
    </div>
  </div>
</div>
