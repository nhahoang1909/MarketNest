@page "/admin/config/commission"
@model MarketNest.Web.Pages.Admin.Config.CommissionModel
@{
  Layout = "_LayoutAdmin";
  ViewData["Title"] = "Commission Rates";
}

<div class="flex gap-5 items-start">
  <partial name="Navigation/_ConfigSubSidebar"/>

  <div class="flex-1 min-w-0 space-y-4">
    <!-- Header -->
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.12em] text-slate-400">— Business</p>
        <h1 class="text-3xl font-bold text-slate-900 mt-1" style="font-family:@AppConstants.Fonts.DisplayShort">Commission Rates</h1>
        <p class="text-[13px] text-slate-500 mt-2 max-w-xl">
          Platform take rate by category or seller tier. Highest matching tier wins; promo overrides applied last.
        </p>
      </div>
    </div>

    <!-- Commission settings card -->
    <div class="rounded-2xl bg-white border border-slate-200/80 overflow-hidden" x-data="{ commission: 10, payoutWindow: '14' }">
      <div class="p-6 space-y-8">
        <!-- Commission rate slider -->
        <div>
          <label class="text-sm font-semibold text-slate-900 block mb-1">Commission rate</label>
          <p class="text-xs text-slate-500 mb-3">Percentage taken from each transaction</p>
          <div class="flex items-center gap-4">
            <input type="range" min="0" max="20" step="0.5" x-model="commission"
                   class="flex-1 h-2 rounded-full appearance-none cursor-pointer" style="accent-color:@AppConstants.Colors.Ink;"/>
            <div class="w-20 text-center">
              <span class="mn-mono text-lg font-bold text-slate-900" x-text="commission + '%'"></span>
            </div>
          </div>
          <div class="flex justify-between mt-1">
            <span class="text-[10px] text-slate-400">0%</span>
            <span class="text-[10px] text-slate-400">20%</span>
          </div>
        </div>

        <hr class="border-slate-100"/>

        <!-- Payout window -->
        <div>
          <label class="text-sm font-semibold text-slate-900 block mb-1">Payout window</label>
          <p class="text-xs text-slate-500 mb-3">Hold period before releasing funds to sellers</p>
          <select x-model="payoutWindow"
                  class="px-4 py-2.5 text-sm rounded-xl border border-slate-200 bg-white focus:border-slate-400 focus:ring-2 focus:ring-accent-400/20 focus:outline-none transition-all w-48">
            <option value="7">7 days</option>
            <option value="14">14 days</option>
            <option value="30">30 days</option>
          </select>
        </div>
      </div>

      <!-- Save button -->
      <div class="px-6 py-4 border-t border-slate-100 flex justify-end">
        <button class="px-6 py-2.5 text-sm font-semibold rounded-xl transition-colors"
                style="background:@AppConstants.Colors.Accent; color:#ffffff;"
                disabled>
          Save configuration
        </button>
      </div>
    </div>

    <!-- Info note -->
    <div class="p-4 rounded-xl border border-dashed border-slate-200 bg-slate-50/50 text-[12px] text-slate-500 leading-relaxed">
      <strong class="text-slate-700">Note</strong> — Commission configuration is read-only in Phase 1.
      Per-category and per-tier rates will be available in Phase 3 when full CRUD is implemented.
    </div>
  </div>
</div>
