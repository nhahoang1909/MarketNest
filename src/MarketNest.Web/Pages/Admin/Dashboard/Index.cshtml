@page "/admin/dashboard"
@model MarketNest.Web.Pages.Admin.Dashboard.IndexModel
@{
  Layout = "_LayoutAdmin";
  ViewData["Title"] = AppConstants.Defaults.FallbackPageTitle;
}

<!-- KPI stat cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <!-- Tong GMV -->
  <div class="stat-forest rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium uppercase tracking-wider" style="color:rgba(255,255,255,0.5);">Tong GMV</span>
      <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full"
            style="background:rgba(0,117,74,0.15); color:@AppConstants.Colors.Accent;">+18%</span>
    </div>
    <p class="text-2xl font-bold mn-mono text-white">156.200.000d</p>
    <p class="text-xs mt-1" style="color:rgba(255,255,255,0.4);">Tong gia tri giao dich</p>
  </div>

  <!-- Nguoi dung -->
  <div class="stat-ink rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium uppercase tracking-wider" style="color:rgba(255,255,255,0.5);">Nguoi dung</span>
      <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full"
            style="background:rgba(0,117,74,0.15); color:@AppConstants.Colors.Accent;">+56</span>
    </div>
    <p class="text-2xl font-bold mn-mono text-white">1,234</p>
    <p class="text-xs mt-1" style="color:rgba(255,255,255,0.4);">Tong nguoi dung</p>
  </div>

  <!-- Don hang -->
  <div class="rounded-2xl p-5" style="background:@AppConstants.Colors.AccentBg;">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium uppercase tracking-wider" style="color:@AppConstants.Colors.AccentDarker;">Don hang</span>
      <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full"
            style="background:rgba(0,79,52,0.1); color:@AppConstants.Colors.AccentDarker;">+127</span>
    </div>
    <p class="text-2xl font-bold mn-mono" style="color:@AppConstants.Colors.AccentDeep;">3,456</p>
    <p class="text-xs mt-1" style="color:@AppConstants.Colors.AccentMuted;">Tong don hang</p>
  </div>

  <!-- Khieu nai cho -->
  <div class="rounded-2xl p-5" style="background:@AppConstants.Colors.WarningBg;">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium uppercase tracking-wider" style="color:@AppConstants.Colors.WarningText;">Khieu nai cho</span>
      <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full"
            style="background:rgba(239,68,68,0.1); color:#ef4444;">+3</span>
    </div>
    <p class="text-2xl font-bold mn-mono" style="color:@AppConstants.Colors.WarningTextDark;">12</p>
    <p class="text-xs mt-1" style="color:@AppConstants.Colors.WarningBorder;">Can xu ly</p>
  </div>
</div>

<!-- GMV Chart -->
<div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6 mb-6" x-data="{ period: '30d' }">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Bieu do GMV</h2>
      <p class="text-xs text-slate-500 mt-0.5">Tong gia tri giao dich theo thoi gian</p>
    </div>
    <div class="flex gap-1">
      <button @@click="period = '7d'" :class="period === '7d' ? 'text-white' : 'text-slate-500 hover:bg-slate-100'"
              :style="period === '7d' ? 'background:#1E3932' : ''"
              class="px-3 py-1 text-xs font-medium rounded-lg transition-colors">7 ngay
      </button>
      <button @@click="period = '30d'" :class="period === '30d' ? 'text-white' : 'text-slate-500 hover:bg-slate-100'"
              :style="period === '30d' ? 'background:#1E3932' : ''"
              class="px-3 py-1 text-xs font-medium rounded-lg transition-colors">30 ngay
      </button>
      <button @@click="period = '90d'" :class="period === '90d' ? 'text-white' : 'text-slate-500 hover:bg-slate-100'"
              :style="period === '90d' ? 'background:#1E3932' : ''"
              class="px-3 py-1 text-xs font-medium rounded-lg transition-colors">90 ngay
      </button>
      <button @@click="period = '1y'" :class="period === '1y' ? 'text-white' : 'text-slate-500 hover:bg-slate-100'"
              :style="period === '1y' ? 'background:#1E3932' : ''"
              class="px-3 py-1 text-xs font-medium rounded-lg transition-colors">1 nam
      </button>
    </div>
  </div>
  <svg viewBox="0 0 800 200" class="w-full h-auto" style="max-height:200px;">
    <defs>
      <linearGradient id="gmvGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1F3A2E" stop-opacity="0.2"/>
        <stop offset="100%" stop-color="#1F3A2E" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <!-- Grid lines -->
    <line x1="0" y1="50" x2="800" y2="50" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4"/>
    <line x1="0" y1="100" x2="800" y2="100" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4"/>
    <line x1="0" y1="150" x2="800" y2="150" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4"/>
    <!-- Area fill -->
    <polygon
      points="0,180 0,140 60,130 120,125 180,100 240,110 300,80 360,90 420,60 480,70 540,50 600,55 660,35 720,40 780,25 800,25 800,180"
      fill="url(#gmvGrad)"/>
    <!-- Line -->
    <polyline
      points="0,140 60,130 120,125 180,100 240,110 300,80 360,90 420,60 480,70 540,50 600,55 660,35 720,40 780,25"
      fill="none" stroke="#1F3A2E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <!-- Endpoint dot -->
    <circle cx="780" cy="25" r="4" fill="#1F3A2E" stroke="white" stroke-width="2"/>
    <!-- Y-axis labels -->
    <text x="10" y="47" fill="#94a3b8" font-size="10" font-family="Geist Mono, monospace">200M</text>
    <text x="10" y="97" fill="#94a3b8" font-size="10" font-family="Geist Mono, monospace">150M</text>
    <text x="10" y="147" fill="#94a3b8" font-size="10" font-family="Geist Mono, monospace">100M</text>
  </svg>
</div>

<!-- System Health + Recent Users -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- System health -->
  <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm p-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-400 mb-1">He thong</p>
        <h3 class="text-base font-semibold text-slate-900">Trang thai he thong</h3>
      </div>
      <span class="text-[11px] font-semibold px-2.5 py-1 rounded-full" style="background:#dcfce7; color:#166534;">Hoat
        dong tot</span>
    </div>
    <!-- Uptime bars (28 days) -->
    <div class="mt-4">
      <p class="text-xs text-slate-500 mb-2">Uptime 28 ngay qua</p>
      <div class="flex gap-0.5">
        @for (var i = 0; i < 28; i++)
        {
          <div class="flex-1 h-6 rounded-sm" style="background:#22c55e;" title="Ngay @(i + 1): 100% uptime"></div>
        }
      </div>
      <div class="flex items-center justify-between mt-2">
        <span class="text-[10px] text-slate-400">28 ngay truoc</span>
        <span class="text-[10px] text-slate-400">Hom nay</span>
      </div>
    </div>
    <!-- Service status -->
    <div class="mt-5 space-y-2.5">
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-600">PostgreSQL</span>
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-600">Redis</span>
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-600">RabbitMQ</span>
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-600">Email (MailHog)</span>
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
      </div>
    </div>
  </div>

  <!-- Recent users -->
  <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200/80 shadow-sm">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">Nguoi dung moi</h2>
      <a href="@AppRoutes.Admin.Users"
         class="text-xs font-medium text-slate-500 hover:text-slate-900 transition-colors">Xem tat
        ca &rarr;</a>
    </div>
    <div class="overflow-x-auto">
      <table class="admin-table w-full text-sm">
        <thead>
        <tr class="border-b border-slate-100">
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Avatar</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Ten</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Vai tro</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Trang thai</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Ngay tham gia
          </th>
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
        @{
          var users = new[]
          {
            new
            {
              Name = "Nguyen Van A", Email = "nguyenvana@email.com", Initial = "A", Color = "#3b82f6", Role = EntityStatusNames.Buyer,
              RoleBadge = $"background:{AppConstants.Colors.BadgeBuyerBg}; color:{AppConstants.Colors.BadgeBuyerText};", Status = EntityStatusNames.Active, Date = "25/04/2026"
            },
            new
            {
              Name = "Tran Thi B", Email = "tranthib@email.com", Initial = "B", Color = "#ec4899", Role = EntityStatusNames.Seller,
              RoleBadge = $"background:{AppConstants.Colors.BadgeSellerBg}; color:{AppConstants.Colors.BadgeSellerText};", Status = EntityStatusNames.Active, Date = "24/04/2026"
            },
            new
            {
              Name = "Le Van C", Email = "levanc@email.com", Initial = "C", Color = "#8b5cf6", Role = EntityStatusNames.Buyer,
              RoleBadge = $"background:{AppConstants.Colors.BadgeBuyerBg}; color:{AppConstants.Colors.BadgeBuyerText};", Status = EntityStatusNames.Active, Date = "23/04/2026"
            },
            new
            {
              Name = "Pham Thi D", Email = "phamthid@email.com", Initial = "D", Color = "#f59e0b", Role = EntityStatusNames.Seller,
              RoleBadge = $"background:{AppConstants.Colors.BadgeSellerBg}; color:{AppConstants.Colors.BadgeSellerText};", Status = EntityStatusNames.Active, Date = "22/04/2026"
            },
            new
            {
              Name = "Hoang Van E", Email = "hoangvane@email.com", Initial = "E", Color = "#10b981", Role = EntityStatusNames.Admin,
              RoleBadge = $"background:{AppConstants.Colors.BadgeAdminBg}; color:{AppConstants.Colors.BadgeAdminText};", Status = EntityStatusNames.Active, Date = "20/04/2026"
            },
            new
            {
              Name = "Vo Thi F", Email = "vothif@email.com", Initial = "F", Color = "#6366f1", Role = EntityStatusNames.Buyer,
              RoleBadge = $"background:{AppConstants.Colors.BadgeBuyerBg}; color:{AppConstants.Colors.BadgeBuyerText};", Status = EntityStatusNames.Suspended, Date = "18/04/2026"
            }
          };
          foreach (var u in users)
          {
            <tr class="hover:bg-slate-50/50 transition-colors">
              <td class="px-4 py-3">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white"
                     style="background:@u.Color;">@u.Initial</div>
              </td>
              <td class="px-4 py-3 font-medium text-slate-900">@u.Name</td>
              <td class="px-4 py-3 text-slate-500 text-xs">@u.Email</td>
              <td class="px-4 py-3">
                <span class="text-[11px] px-2 py-0.5 rounded-full font-medium" style="@u.RoleBadge">@u.Role</span>
              </td>
              <td class="px-4 py-3">
                @if (u.Status == EntityStatusNames.Active)
                {
                  <span class="text-[11px] px-2 py-0.5 rounded-full font-medium"
                        style="background:@AppConstants.Colors.BadgeActiveBg; color:@AppConstants.Colors.BadgeActiveText;">@EntityStatusNames.Active</span>
                }
                else
                {
                  <span class="text-[11px] px-2 py-0.5 rounded-full font-medium"
                        style="background:@AppConstants.Colors.BadgeSuspendedBg; color:@AppConstants.Colors.BadgeSuspendedText;">@EntityStatusNames.Suspended</span>
                }
              </td>
              <td class="px-4 py-3 text-xs text-slate-500">@u.Date</td>
            </tr>
          }
        }
        </tbody>
      </table>
    </div>
  </div>
</div>
