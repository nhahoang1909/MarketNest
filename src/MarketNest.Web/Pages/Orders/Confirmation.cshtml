@page "/orders/{orderId:guid}/confirmation"
@model ConfirmationModel
@{
  ViewData["Title"] = "Dat hang thanh cong";
}

<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 flex justify-center">
  <div class="w-full max-w-lg">
    <div class="card p-8 lg:p-10 text-center">

      <!-- Success icon -->
      <div class="w-20 h-20 rounded-full bg-success-100 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-success-500" fill="none" stroke="currentColor" stroke-width="2.5"
             viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </div>

      <h1 class="mn-h3 text-ink-800 mb-2">Dat hang thanh cong!</h1>
      <p class="text-ink-500 mb-6">Cam on ban da mua sam tai MarketNest. Don hang cua ban dang duoc xu ly.</p>

      <!-- Order ID -->
      <div class="bg-cream-100 rounded-2xl p-4 mb-8">
        <p class="text-xs text-ink-400 mb-1">Ma don hang</p>
        <p class="mn-mono text-ink-800 font-bold text-sm tracking-wide">@Model.OrderId</p>
      </div>

      <!-- Order summary -->
      <div class="text-left space-y-4 mb-8">
        <h2 class="mn-h5 text-ink-700">Chi tiet don hang</h2>

        <div class="divide-y divide-ink-100">
          <div class="flex justify-between py-2.5 text-sm">
            <span class="text-ink-600">Binh gom men ngoc x1</span>
            <span class="text-ink-700 font-medium mn-mono">450.000&#8363;</span>
          </div>
          <div class="flex justify-between py-2.5 text-sm">
            <span class="text-ink-600">Loa go bluetooth mini x2</span>
            <span class="text-ink-700 font-medium mn-mono">1.500.000&#8363;</span>
          </div>
          <div class="flex justify-between py-2.5 text-sm">
            <span class="text-ink-600">Khan lua to tam x1</span>
            <span class="text-ink-700 font-medium mn-mono">1.250.000&#8363;</span>
          </div>
        </div>

        <div class="border-t border-ink-100 pt-3 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-ink-500">Tam tinh</span>
            <span class="text-ink-700 mn-mono">3.200.000&#8363;</span>
          </div>
          <div class="flex justify-between">
            <span class="text-ink-500">Phi van chuyen</span>
            <span class="text-ink-700 mn-mono">25.000&#8363;</span>
          </div>
          <div class="flex justify-between font-semibold pt-2 border-t border-ink-100">
            <span class="text-ink-800">Tong cong</span>
            <span class="text-accent-600 mn-mono text-lg">3.225.000&#8363;</span>
          </div>
        </div>

        <!-- Shipping address -->
        <div class="pt-4">
          <p class="text-xs text-ink-400 mb-1">Dia chi giao hang</p>
          <p class="text-sm text-ink-600">Nguyen Van A</p>
          <p class="text-sm text-ink-500">123 Nguyen Hue, Phuong Ben Nghe, Quan 1, TP. Ho Chi Minh</p>
        </div>

        <!-- Payment method -->
        <div>
          <p class="text-xs text-ink-400 mb-1">Phuong thuc thanh toan</p>
          <p class="text-sm text-ink-600">Thanh toan khi nhan hang (COD)</p>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/account/orders" class="btn-primary flex-1 text-center">Xem don hang</a>
        <a href="/shop" class="btn-ghost flex-1 text-center">Tiep tuc mua sam</a>
      </div>
    </div>
  </div>
</div>
