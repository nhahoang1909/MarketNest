@*
  Excel file upload — drag-drop or browse for .xlsx/.xls, enforces FieldLimits.FileUpload.
  Parameters (via ViewData):
    Name       — input name/id (required)
    Label      — visible label text (default: "Import file")
    HelpText   — hint below dropzone
    Errors     — IEnumerable<string> validation errors
*@
@{
  var name     = ViewData["Name"]?.ToString() ?? "importFile";
  var label    = ViewData["Label"]?.ToString() ?? "Import file";
  var helpText = ViewData["HelpText"]?.ToString()
              ?? $"Excel files only (.xlsx, .xls). Max {FieldLimits.FileUpload.MaxExcelSizeBytes / 1024 / 1024} MB. Up to {FieldLimits.ExcelImport.MaxRowsPerBatch:N0} rows per batch.";
  var errors   = ViewData["Errors"] as IEnumerable<string>;
  var hasError = errors?.Any() == true;
  var accept   = string.Join(",", FieldLimits.FileUpload.AllowedExcelTypes);
}

<div class="space-y-2"
     x-data="{ fileName: '', hasFile: false, isDragging: false,
                handleFile(f) { this.fileName = f.name; this.hasFile = true; } }">
  <label class="form-label">@label</label>

  <div class="relative rounded-xl border-2 border-dashed p-6 text-center transition-all duration-200 cursor-pointer"
       :class="{
         'border-danger-400 bg-danger-50': @(hasError ? "true" : "false"),
         'border-accent-400 bg-accent-50': isDragging && !@(hasError ? "true" : "false"),
         'border-ink-200 hover:border-ink-300': !isDragging && !@(hasError ? "true" : "false"),
         'bg-accent-50 border-accent-400': hasFile && !@(hasError ? "true" : "false")
       }"
       x-on:dragover.prevent="isDragging = true"
       x-on:dragleave.prevent="isDragging = false"
       x-on:drop.prevent="isDragging = false; if ($event.dataTransfer.files[0]) { handleFile($event.dataTransfer.files[0]); $el.querySelector('input').files = $event.dataTransfer.files; }">

    <!-- Icon -->
    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl"
         :class="hasFile ? 'bg-accent-100' : 'bg-cream-100'">
      <svg class="h-6 w-6" :class="hasFile ? 'text-accent-600' : 'text-ink-400'"
           xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
    </div>

    <!-- State: file selected -->
    <div x-show="hasFile" class="text-sm">
      <p class="font-semibold text-accent-700" x-text="fileName"></p>
      <button type="button" class="mt-1 text-xs text-ink-400 hover:text-ink-600 underline"
              x-on:click.stop="hasFile = false; fileName = ''; $el.closest('[x-data]').querySelector('input').value = ''">
        Remove
      </button>
    </div>

    <!-- State: no file / drag hint -->
    <div x-show="!hasFile" class="text-sm">
      <label class="cursor-pointer">
        <span class="font-medium text-accent-600 hover:text-accent-500">Browse file</span>
        <span class="text-ink-400"> or drag & drop here</span>
        <input type="file" id="@name" name="@name"
               accept="@accept"
               class="sr-only"
               x-on:change="if ($event.target.files[0]) handleFile($event.target.files[0])"/>
      </label>
      <p class="mt-1 text-xs text-ink-400">.xlsx, .xls</p>
    </div>
  </div>

  @if (hasError)
  {
    @foreach (var error in errors!)
    {
      <p class="form-error">
        <svg class="h-3.5 w-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
        @error
      </p>
    }
  }
  @if (!string.IsNullOrEmpty(helpText) && !hasError)
  {
    <p class="form-help">@helpText</p>
  }
</div>

