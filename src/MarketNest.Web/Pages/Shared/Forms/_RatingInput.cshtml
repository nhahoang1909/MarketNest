@*
  Rating input — star rating selector 1–5 using radio buttons + Alpine.js.
  Parameters (via ViewData):
    Label      — visible label text (required)
    Name       — input name/id (required)
    Value      — current rating 1–5 (default: 0 = none)
    HelpText   — hint shown below input
    ReadOnly   — "true" renders display-only stars (no interaction)
    Errors     — IEnumerable<string> validation errors
*@
@{
  var label    = ViewData["Label"]?.ToString() ?? "Rating";
  var name     = ViewData["Name"]?.ToString() ?? "rating";
  var valueStr = ViewData["Value"]?.ToString() ?? "0";
  var helpText = ViewData["HelpText"]?.ToString();
  var readOnly = ViewData["ReadOnly"]?.ToString() == "true";
  var errors   = ViewData["Errors"] as IEnumerable<string>;
  var hasError = errors?.Any() == true;
  int.TryParse(valueStr, out var currentRating);
}

<div class="space-y-1">
  <label class="form-label">@label</label>

  @if (readOnly)
  {
    <div class="flex items-center gap-0.5" aria-label="@currentRating out of 5 stars">
      @for (int i = 1; i <= FieldLimits.Rating.Max; i++)
      {
        <svg class="h-5 w-5 @(i <= currentRating ? "text-mustard-400" : "text-ink-200")"
             fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      }
    </div>
  }
  else
  {
    <div x-data="{ hovered: 0, rating: @currentRating }" class="flex items-center gap-0.5">
      @for (int i = 1; i <= FieldLimits.Rating.Max; i++)
      {
        <label class="cursor-pointer" title="@i star@(i > 1 ? "s" : "")">
          <input type="radio" name="@name" value="@i" class="sr-only"
                 @(i == currentRating ? "checked" : "")
                 x-on:change="rating = @i"/>
          <svg class="h-7 w-7 transition-colors duration-100"
               :class="(@i <= hovered || @i <= rating) ? 'text-mustard-400' : 'text-ink-200'"
               x-on:mouseenter="hovered = @i"
               x-on:mouseleave="hovered = 0"
               fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </label>
      }
      <span class="ml-2 text-sm text-ink-400" x-text="rating > 0 ? rating + '/5' : 'No rating'">
        @(currentRating > 0 ? $"{currentRating}/5" : "No rating")
      </span>
    </div>
  }

  @if (hasError)
  {
    @foreach (var error in errors!)
    {
      <p class="form-error">
        <svg class="h-3.5 w-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
        @error
      </p>
    }
  }
  @if (!string.IsNullOrEmpty(helpText) && !hasError)
  {
    <p class="form-help">@helpText</p>
  }
</div>

