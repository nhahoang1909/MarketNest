@* Filter bar — pass Filters, TargetUrl, TargetId, ParamName, IndicatorId (optional) via ViewData *@
@{
  var filters = ViewData["Filters"] as IEnumerable<(string Label, string Value, bool Active)>
                ?? Enumerable.Empty<(string Label, string Value, bool Active)>();
  var targetUrl = ViewData["TargetUrl"]?.ToString() ?? "";
  var targetId = ViewData["TargetId"]?.ToString() ?? "#results";
  var paramName = ViewData["ParamName"]?.ToString() ?? "filter";
  var indicatorId = ViewData["IndicatorId"]?.ToString();
}

<div class="flex flex-wrap gap-2">
  @foreach (var (label, value, active) in filters)
  {
    <button type="button" class="@(active ? "filter-chip-active" : "filter-chip")"
            hx-get="@(targetUrl)?@(paramName)=@value"
            hx-target="@targetId"
            hx-push-url="true"
            @(indicatorId != null ? $"hx-indicator=\"{indicatorId}\"" : "")>
      @label
    </button>
  }
</div>
