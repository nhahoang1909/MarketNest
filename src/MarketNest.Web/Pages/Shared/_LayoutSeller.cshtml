@* Seller dashboard layout — White sidebar with accent lime highlights *@
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    var currentPath  = Context.Request.Path.Value ?? "";
    var requestToken = Antiforgery.GetAndStoreTokens(Context);
    var pageTitle    = ViewData["Title"]?.ToString() ?? "Dashboard";
}
<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#C8F25C" />
    <title>@pageTitle – Kenh ban hang · MarketNest</title>

    <!-- Fonts: Fraunces (display) + Geist (UI) + Geist Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/style.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-mono/style.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="htmx-config"
          content='{"defaultSwapStyle":"outerHTML","globalViewTransitions":true,"getCacheBusterParam":true}'>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js" defer></script>
    <script src="https://unpkg.com/htmx.org@@2.0.4" defer></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@@3.x.x/dist/cdn.min.js"></script>

    <script src="~/js/stores/toasts.js" defer></script>
    <script src="~/js/stores/user.js" defer></script>
    <script src="~/js/components/productForm.js" defer></script>
    <script src="~/js/magic/htmxHelpers.js" defer></script>
    <script src="~/js/app.js" defer></script>

    <style>
        body.layout-seller { font-family: 'Geist', system-ui, sans-serif; }
        .font-display { font-family: 'Fraunces', serif; }
        .mn-mono { font-family: 'Geist Mono', monospace; }

        .seller-topbar {
            backdrop-filter: blur(8px);
            background: rgba(255,255,255,0.96);
        }

        /* Active nav item — accent lime left border */
        .sidebar-link-active {
            position: relative;
        }
        .sidebar-link-active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 3px;
            background: #C8F25C;
            border-radius: 0 2px 2px 0;
        }
    </style>

    @await RenderSectionAsync("Head", required: false)
</head>

<body class="layout-seller min-h-screen" x-data="{ sidebarOpen: false }" style="background:#f5f0e8;">
    <input type="hidden" name="__RequestVerificationToken" value="@requestToken.RequestToken" />

    <!-- MOBILE OVERLAY -->
    <div x-show="sidebarOpen"
         x-cloak
         @@click="sidebarOpen = false"
         x-transition:enter="transition duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition duration-150"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-40 bg-black/30 backdrop-blur-sm lg:hidden">
    </div>

    <!-- SIDEBAR -->
    <aside class="fixed inset-y-0 left-0 z-50 w-60 bg-white border-r border-gray-100
                  flex flex-col transition-transform duration-300 ease-in-out
                  -translate-x-full lg:translate-x-0 shadow-sm"
           :class="{ 'translate-x-0': sidebarOpen, '-translate-x-full': !sidebarOpen }"
           x-cloak>

        <!-- Logo + SELLER badge -->
        <div class="flex items-center h-[60px] px-5 border-b border-gray-100 shrink-0">
            <a href="/" class="flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-ink-700 flex items-center justify-center shrink-0"
                      style="background:#1e293b;">
                    <span class="text-accent-400 font-display italic text-base font-semibold leading-none"
                          style="color:#C8F25C; font-family:'Fraunces',serif; font-style:italic;">m</span>
                </span>
                <span class="text-lg font-semibold text-gray-900 leading-none"
                      style="font-family:'Geist',sans-serif; letter-spacing:-0.3px">MarketNest</span>
            </a>
            <span class="ml-auto text-[9px] font-bold uppercase tracking-widest text-accent-800
                         bg-accent-100 px-2 py-0.5 rounded-full border border-accent-200"
                  style="color:#3d5a00; background:#f0fbc4; border-color:#d4ed7a;">
                Seller
            </span>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-0.5">

            <a href="/seller/dashboard" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/dashboard") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/dashboard") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
                </svg>
                <span>Dashboard</span>
            </a>

            <a href="/seller/storefront" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/storefront") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/storefront") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/>
                </svg>
                <span>Cua hang</span>
            </a>

            <a href="/seller/products" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/products") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/products") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>
                </svg>
                <span>San pham</span>
            </a>

            <a href="/seller/orders" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/orders") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/orders") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>
                </svg>
                <span>Don hang</span>
            </a>

            <a href="/seller/payouts" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/payouts") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/payouts") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/>
                </svg>
                <span>Thanh toan</span>
            </a>

            <a href="/seller/reviews" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/reviews") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/reviews") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
                </svg>
                <span>Danh gia</span>
            </a>

            <a href="/seller/disputes" mn-nav
               class="sidebar-link @(currentPath.StartsWith("/seller/disputes") ? "sidebar-link-active" : "")">
                <svg class="w-[18px] h-[18px] shrink-0"
                     style="@(currentPath.StartsWith("/seller/disputes") ? "color:#7db000" : "color:#9ca3af")"
                     fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                </svg>
                <span>Khieu nai</span>
            </a>
        </nav>

        <!-- Sidebar footer — quick store stats -->
        <div class="shrink-0 border-t border-gray-100 p-4 space-y-3">
            <!-- Mini stat row -->
            <div class="grid grid-cols-2 gap-2">
                <div class="rounded-lg bg-accent-100 p-2.5 text-center"
                     style="background:#f0fbc4;">
                    <p class="text-xs text-accent-800 font-semibold leading-none mb-1" style="color:#3d5a00;">Hom nay</p>
                    <p class="text-sm font-bold text-accent-900 mn-mono" style="color:#2d4400;">0</p>
                    <p class="text-[10px] text-accent-600" style="color:#5c8a00;">don hang</p>
                </div>
                <div class="rounded-lg bg-success-50 p-2.5 text-center"
                     style="background:#f0fdf4;">
                    <p class="text-xs text-success-600 font-semibold leading-none mb-1" style="color:#16a34a;">Doanh thu</p>
                    <p class="text-sm font-bold text-success-700 mn-mono" style="color:#15803d;">0d</p>
                    <p class="text-[10px] text-success-500" style="color:#22c55e;">hom nay</p>
                </div>
            </div>
            <!-- Settings link -->
            <a href="/account/settings"
               class="sidebar-link text-gray-500 hover:text-gray-700">
                <svg class="w-[18px] h-[18px] shrink-0 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                </svg>
                <span class="text-sm">Cai dat</span>
            </a>
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="lg:ml-60 flex flex-col min-h-screen">

        <!-- TOP BAR -->
        <header class="seller-topbar sticky top-0 z-40 border-b border-gray-100
                       flex items-center h-[60px] px-4 sm:px-6 gap-4">

            <!-- Mobile hamburger -->
            <button @@click="sidebarOpen = !sidebarOpen"
                    class="lg:hidden btn-icon text-gray-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                </svg>
            </button>

            <!-- Page title breadcrumb -->
            <div class="flex items-center gap-2 min-w-0">
                <a href="/seller/dashboard"
                   class="text-gray-400 hover:text-gray-600 transition-colors text-sm font-medium">
                    Kenh ban hang
                </a>
                <svg class="w-3.5 h-3.5 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
                </svg>
                <span class="text-sm font-semibold text-gray-900 truncate">@pageTitle</span>
            </div>

            <div class="flex-1"></div>

            <!-- Back to shop link -->
            <a href="/"
               class="hidden sm:flex items-center gap-1.5 text-sm text-gray-500 hover:text-accent-700 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                </svg>
                Ve trang mua sam
            </a>

            <!-- Notifications -->
            <button class="btn-icon text-gray-500 relative">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
                </svg>
            </button>

            <!-- Seller avatar -->
            <div x-data="{ open: false }" class="relative">
                <button @@click="open = !open"
                        class="flex items-center gap-2 rounded-xl px-2 py-1.5 hover:bg-gray-50 transition-colors">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0"
                         style="background:linear-gradient(135deg,#16a34a,#22c55e)"
                         x-text="($store.user.name || 'S').charAt(0).toUpperCase()">
                    </div>
                    <span class="hidden sm:block text-sm font-semibold text-gray-800 max-w-[90px] truncate"
                          x-text="$store.user.name ?? 'Seller'"></span>
                    <svg class="w-3.5 h-3.5 text-gray-400 hidden sm:block transition-transform"
                         :class="{'rotate-180': open}"
                         fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                    </svg>
                </button>

                <div x-show="open" @@click.away="open = false" x-cloak
                     x-transition:enter="transition ease-out duration-150"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 py-1.5 z-50 origin-top-right">
                    <a href="/account/settings" class="flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                        </svg>
                        Tai khoan
                    </a>
                    <a href="/account/orders" class="flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>
                        </svg>
                        Don cua toi
                    </a>
                    <div class="border-t border-gray-100 mt-1 pt-1">
                        <button @@click="$store.user.logout()"
                                class="flex items-center gap-2.5 w-full px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15M12 9l3 3m0 0-3 3m3-3H2.25"/>
                            </svg>
                            Dang xuat
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="flex-1 p-5 sm:p-6">
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="px-6 py-3 border-t border-gray-100 flex items-center justify-between bg-white">
            <span class="text-xs text-gray-400">
                &copy; @DateTime.UtcNow.Year MarketNest · Kenh ban hang
            </span>
            <a href="/" class="text-xs text-gray-400 hover:text-accent-600 transition-colors">
                Ve trang mua sam &rarr;
            </a>
        </footer>
    </div>

    <!-- TOASTS -->
    <div class="fixed bottom-5 right-5 z-[9999] flex flex-col gap-2.5 max-w-sm pointer-events-none" x-data x-cloak>
        <template x-for="toast in $store.toasts.items" :key="toast.id">
            <div x-show="toast.visible"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-end="opacity-0 scale-95"
                 :class="{
                     'border-success-300 bg-success-50 text-success-900': toast.type === 'success',
                     'border-red-300 bg-red-50 text-red-900':             toast.type === 'error',
                     'border-amber-300 bg-amber-50 text-amber-900':       toast.type === 'warning',
                     'border-accent-300 bg-accent-50 text-accent-900':    toast.type === 'info'
                 }"
                 class="pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl border shadow-lg">
                <span x-text="toast.message" class="text-sm font-medium flex-1"></span>
                <button @@click="$store.toasts.dismiss(toast.id)" class="opacity-50 hover:opacity-100 transition-opacity">&times;</button>
            </div>
        </template>
    </div>

    <script>
        document.addEventListener('showToast', function (e) {
            const { message, type } = e.detail ?? {};
            if (message && window.Alpine) Alpine.store('toasts').show(message, type ?? 'info');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
