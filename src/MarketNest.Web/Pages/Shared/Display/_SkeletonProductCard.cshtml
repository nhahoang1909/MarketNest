@* Skeleton placeholder for product card grid.
   Pass Count (int, default 8) and Cols ("2" | "3" | "4", default "4") via ViewData. *@
@{
  var count = int.TryParse(ViewData["Count"]?.ToString(), out var c) ? c : 8;
  var cols = ViewData["Cols"]?.ToString() ?? "4";
  var gridCss = cols switch
  {
    "2" => "grid-cols-2",
    "3" => "grid-cols-2 md:grid-cols-3",
    _ => "grid-cols-2 md:grid-cols-4"
  };
}

<div class="grid @gridCss gap-4" aria-hidden="true" aria-label="Loading...">
  @for (var i = 0; i < count; i++)
  {
    <div class="skeleton-product-card">
      <div class="sk-image"></div>
      <div class="sk-body">
        <div class="sk-title"></div>
        <div class="sk-sub"></div>
        <div class="sk-price"></div>
      </div>
    </div>
  }
</div>
