@* Status badge — pass Status, ColorMap (optional Dictionary<string,string>) via ViewData *@
@{
  var status = ViewData["Status"]?.ToString() ?? EntityStatusNames.Unknown;
  var colorMap = ViewData["ColorMap"] as Dictionary<string, string>;
  var badgeCss = "badge badge-gray";
  if (colorMap != null && colorMap.TryGetValue(status, out var css))
  {
    badgeCss = $"badge {css}";
  }
  else
  {
    badgeCss = status.ToLower() switch
    {
      EntityStatusNames.Active or EntityStatusNames.Completed or EntityStatusNames.Approved or EntityStatusNames.Delivered => "badge badge-green",
      EntityStatusNames.Pending or EntityStatusNames.Processing => "badge badge-yellow",
      EntityStatusNames.Cancelled or EntityStatusNames.Rejected or EntityStatusNames.Failed => "badge badge-red",
      EntityStatusNames.Shipped or EntityStatusNames.InTransit => "badge badge-blue",
      EntityStatusNames.Draft => "badge badge-gray",
      EntityStatusNames.Refunded or EntityStatusNames.Disputed => "badge badge-orange",
      _ => "badge badge-gray"
    };
  }
}

<span class="@badgeCss">@status</span>
