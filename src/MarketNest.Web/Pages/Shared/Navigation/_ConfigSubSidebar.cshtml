<aside class="w-56 shrink-0 hidden lg:block">
  <div class="sticky top-[76px] rounded-2xl border border-slate-200/80 bg-white p-4 space-y-5">
    <div>
      <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">— System config</p>
      <p class="mt-1 text-lg font-bold text-slate-900" style="font-family:@AppConstants.Fonts.DisplayShort">Settings</p>
    </div>

    @foreach (var group in groups)
    {
      <div class="space-y-1">
        <p class="text-[10px] font-bold uppercase tracking-[0.16em] text-slate-400 px-1 pb-1">@group.Label</p>
        @foreach (var item in group.Items)
        {
          var isActive = currentPath.StartsWith(item.Route, StringComparison.OrdinalIgnoreCase);
          <a href="@item.Route"
             class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium transition-all duration-150 @(isActive ? "text-white" : "text-slate-700 hover:bg-slate-50")"
             style="@(isActive ? $"background:{AppConstants.Colors.Ink}" : "")">
            <span class="w-6 h-6 rounded-md flex items-center justify-center shrink-0"
                  style="@(isActive ? $"background:{AppConstants.Colors.Accent}; color:{AppConstants.Colors.Ink}" : "background:#f1f0eb;")">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="@item.Icon"/>
              </svg>
            </span>
            <span class="flex-1 @(isActive ? "font-semibold" : "")">@item.Label</span>
          </a>
        }
      </div>
    }

    <div class="p-3 rounded-lg border border-dashed border-slate-200 bg-slate-50/50 text-[11px] text-slate-500 leading-relaxed">
      <strong class="text-slate-700">Heads up</strong><br/>
      Most settings cascade live. Critical edits require a 2-step confirm.
    </div>
  </div>
</aside>

