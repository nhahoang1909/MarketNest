@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@inject IHtmlLocalizer<SharedResource> SharedLocalizer
@{
  var requestToken = Antiforgery.GetAndStoreTokens(Context);
  var currentPath = Context.Request.Path.Value ?? "";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" class="scroll-smooth"
      x-data="{ theme: localStorage.getItem('mn-theme') || 'light' }"
      :data-theme="theme">

<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="theme-color" content="@AppConstants.Colors.Ink"/>
  <title>@ViewData["Title"] - @AppConstants.AppName</title>

  <!-- Fonts: Playfair Display (display) + DM Sans (UI) + JetBrains Mono -->
  <link rel="preconnect" href="@AppConstants.Fonts.GoogleFontsOrigin"/>
  <link rel="preconnect" href="@AppConstants.Fonts.GoogleFontsStaticOrigin" crossorigin/>
  <link href="@AppConstants.Fonts.DisplayCdn" rel="stylesheet"/>
  <link href="@AppConstants.Fonts.SansCdn" rel="stylesheet"/>
  <link href="@AppConstants.Fonts.MonoCdn" rel="stylesheet"/>

  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>

  <!-- HTMX -->
  <meta name="htmx-config"
        content='{"defaultSwapStyle":"outerHTML","globalViewTransitions":true,"getCacheBusterParam":true}'>
  <script src="https://unpkg.com/htmx.org@@2.0.4" defer></script>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@@3.x.x/dist/cdn.min.js"></script>

  <!-- Alpine stores & components -->
  <script src="~/js/stores/toasts.js" defer></script>
  <script src="~/js/stores/cart.js" defer></script>
  <script src="~/js/stores/user.js" defer></script>
  <script src="~/js/components/searchBar.js" defer></script>
  <script src="~/js/magic/htmxHelpers.js" defer></script>
  <script src="~/js/app.js" defer></script>

  @await RenderSectionAsync("Head", false)
</head>

<body class="min-h-screen flex flex-col bg-cream-100" x-data>
<input type="hidden" name="__RequestVerificationToken" value="@requestToken.RequestToken"/>

<!-- ░░ HEADER ░░ -->
<header class="sticky top-0 z-50 bg-surface border-b border-ink-100/60"
        style="backdrop-filter: blur(12px); background: rgba(255,255,255,0.92);">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 lg:gap-8 h-[72px]">

      <!-- Logo -->
      <a href="@AppRoutes.Home" class="shrink-0 flex items-center gap-2">
        <div class="w-9 h-9 rounded-full bg-accent-400 flex items-center justify-center">
                        <span class="text-white font-bold text-base"
                              style="font-family:@AppConstants.Fonts.DisplayShort">M</span>
        </div>
        <span class="text-lg font-semibold text-ink-700 tracking-tight hidden sm:block">
                        @AppConstants.AppName
                    </span>
      </a>

      <!-- Search (desktop) -->
      <div class="hidden md:flex flex-1 max-w-xl relative" x-data="searchBar()">
        <form action="@AppRoutes.Search" method="get" class="w-full relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-300 pointer-events-none"
               fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/>
          </svg>
          <input type="text" name="q" x-model="query"
                 placeholder="@SharedLocalizer["Nav.Search.Placeholder"]"
                 class="w-full h-[42px] pl-11 pr-4 text-sm rounded-full
                                      border border-ink-200 bg-cream-50
                                      focus:bg-surface focus:border-ink-700 focus:ring-0 focus:outline-none
                                      placeholder:text-ink-300 transition-all duration-200"
                 hx-get="@AppRoutes.SearchSuggestions"
                 hx-trigger="keyup changed delay:350ms"
                 hx-target="#search-suggestions"/>
        </form>
        <div id="search-suggestions"
             class="absolute top-full mt-1 left-0 right-0 bg-surface rounded-2xl
                                shadow-xl border border-ink-100 z-50 overflow-hidden">
        </div>
      </div>

      <!-- Nav links (desktop) -->
      <nav class="hidden lg:flex items-center gap-1">
        <a href="@AppRoutes.Home"
           class="px-3 py-1.5 text-sm font-medium rounded-full transition-colors
                              @(currentPath == AppRoutes.Home ? "bg-accent-400 text-white" : "text-ink-500 hover:text-ink-700 hover:bg-cream-100")">
          @SharedLocalizer["Nav.Home"]
        </a>
        <a href="@AppRoutes.Shop"
           class="px-3 py-1.5 text-sm font-medium rounded-full transition-colors
                              @(currentPath.StartsWith(AppRoutes.Shop) ? "bg-accent-400 text-white" : "text-ink-500 hover:text-ink-700 hover:bg-cream-100")">
          @SharedLocalizer["Nav.Shop"]
        </a>
        <a href="@AppRoutes.Cart"
           class="px-3 py-1.5 text-sm font-medium rounded-full transition-colors
                              @(currentPath.StartsWith(AppRoutes.Cart) ? "bg-accent-400 text-white" : "text-ink-500 hover:text-ink-700 hover:bg-cream-100")">
          @SharedLocalizer["Nav.Cart"]
        </a>
        <a href="@AppRoutes.Account.Orders"
           class="px-3 py-1.5 text-sm font-medium rounded-full transition-colors
                              @(currentPath.StartsWith(AppRoutes.Account.Orders) ? "bg-accent-400 text-white" : "text-ink-500 hover:text-ink-700 hover:bg-cream-100")">
          @SharedLocalizer["Nav.Orders"]
        </a>
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-1 sm:gap-2 shrink-0 ml-auto lg:ml-0">

        <!-- Mobile search trigger -->
        <button class="btn-icon md:hidden" aria-label="@SharedLocalizer["Nav.Search"]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/>
          </svg>
        </button>

        <!-- Wishlist -->
        <a href="@AppRoutes.Account.Wishlist" class="btn-icon hidden sm:inline-flex"
           aria-label="@SharedLocalizer["Nav.Wishlist"]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
          </svg>
        </a>

        <!-- Cart -->
        <a href="@AppRoutes.Cart" class="relative btn-icon" aria-label="@SharedLocalizer["Nav.Cart"]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
          </svg>
          <template x-if="$store.cart.count > 0">
                            <span x-text="$store.cart.count > 99 ? '99+' : $store.cart.count"
                                  class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1
                                         bg-accent-400 text-white text-[10px] font-bold
                                         rounded-full flex items-center justify-center leading-none">
                            </span>
          </template>
        </a>

        <!-- Theme toggle -->
        <button @@click="theme = theme === 'light' ? 'dark' : 'light'; localStorage.setItem('mn-theme', theme)"
                class="btn-icon" aria-label="@SharedLocalizer["Nav.ThemeToggle"]">
          <template x-if="theme === 'light'">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
            </svg>
          </template>
          <template x-if="theme === 'dark'">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
            </svg>
          </template>
        </button>

        <!-- Language switcher -->
        <form method="post" action="@AppRoutes.Api.SetLanguage" class="inline-flex">
          <input type="hidden" name="culture"
                 value="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "vi" ? "en" : "vi")"/>
          <input type="hidden" name="returnUrl" value="@Context.Request.Path"/>
          <button type="submit" class="btn-icon" aria-label="@SharedLocalizer["Nav.SwitchLanguage"]">
                            <span class="text-xs font-bold">
                                @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "vi" ? "EN" : "VI")
                            </span>
          </button>
        </form>

        <!-- Auth: logged out -->
        <template x-if="!$store.user.isAuthenticated">
          <a href="@AppRoutes.Auth.Login"
             class="hidden sm:inline-flex btn-primary text-xs px-4 py-2">
            @SharedLocalizer["Auth.Login"]
          </a>
        </template>

        <!-- Auth: logged in -->
        <template x-if="$store.user.isAuthenticated">
          <div x-data="{ open: false }" class="relative">
            <button @@click="open = !open"
                    class="flex items-center gap-2 rounded-full px-2 py-1.5
                                           hover:bg-cream-100 transition-colors">
              <div class="avatar avatar-sm"
                   x-text="($store.user.name || 'U').charAt(0).toUpperCase()">
              </div>
              <span class="hidden sm:block text-sm font-medium text-ink-600 max-w-[100px] truncate"
                    x-text="$store.user.name"></span>
            </button>

            <div x-show="open"
                 @@click.away="open = false"
                 x-cloak
                 x-transition:enter="transition ease-out duration-150"
                 x-transition:enter-start="opacity-0 scale-95 -translate-y-1"
                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                 x-transition:leave="transition ease-in duration-100"
                 x-transition:leave-end="opacity-0 scale-95"
                 class="absolute right-0 mt-2 w-52 bg-surface rounded-2xl
                                        shadow-xl border border-ink-100 py-1.5 z-50 origin-top-right">
              <div class="px-4 py-2.5 border-b border-ink-100/60">
                <p class="text-xs text-ink-400">@SharedLocalizer["Auth.LoggedInAs"]</p>
                <p class="text-sm font-semibold text-ink-700 truncate"
                   x-text="$store.user.name"></p>
              </div>
              <div class="py-1">
                <a href="@AppRoutes.Account.Settings"
                   class="flex items-center gap-3 px-4 py-2 text-sm text-ink-600 hover:bg-cream-50 transition-colors">
                  @SharedLocalizer["User.Account"]
                </a>
                <a href="@AppRoutes.Account.Orders"
                   class="flex items-center gap-3 px-4 py-2 text-sm text-ink-600 hover:bg-cream-50 transition-colors">
                  @SharedLocalizer["User.MyOrders"]
                </a>
                <a href="@AppRoutes.Seller.Dashboard"
                   class="flex items-center gap-3 px-4 py-2 text-sm text-ink-600 hover:bg-cream-50 transition-colors">
                  @SharedLocalizer["User.SellerDashboard"]
                </a>
              </div>
              <div class="border-t border-ink-100/60 pt-1">
                <button @@click="$store.user.logout()"
                        class="flex items-center gap-3 w-full px-4 py-2 text-sm text-danger-500
                                                   hover:bg-danger-50 transition-colors">
                  @SharedLocalizer["Auth.Logout"]
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>
    </div>
  </div>
</header>

<!-- ░░ MAIN CONTENT ░░ -->
<main class="flex-1">
  @RenderBody()
</main>

<!-- ░░ FOOTER ░░ -->
<footer class="text-cream-200 mt-12" style="background:#1E3932;">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a href="@AppRoutes.Home" class="inline-flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-full bg-accent-400 flex items-center justify-center">
                            <span class="text-white font-bold"
                                  style="font-family:@AppConstants.Fonts.DisplayShort">M</span>
          </div>
          <span class="text-xl font-semibold text-cream-100 tracking-tight">@AppConstants.AppName</span>
        </a>
        <p class="text-sm text-cream-400 leading-relaxed mb-6 max-w-xs">
          @SharedLocalizer["Footer.Description"]
        </p>
        <!-- Newsletter -->
        <div class="flex gap-2 max-w-xs">
          <input type="email" placeholder="@SharedLocalizer["Footer.Newsletter.Placeholder"]"
                 class="flex-1 h-10 px-4 text-sm rounded-full bg-white/10 border border-white/10
                                      text-cream-100 placeholder:text-cream-500
                                      focus:bg-white/15 focus:border-accent-400 focus:outline-none transition-all"/>
          <button class="h-10 px-5 text-sm font-semibold rounded-full
                                       bg-accent-400 text-white hover:bg-accent-500 transition-colors">
            @SharedLocalizer["Footer.Newsletter.Subscribe"]
          </button>
        </div>
      </div>

      <!-- Links columns -->
      <div>
        <h4
          class="text-[11px] font-bold text-cream-100 mb-4 uppercase tracking-[0.12em]">@SharedLocalizer["Footer.Shopping"]</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="@AppRoutes.Shop"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Shopping.AllProducts"]</a>
          </li>
          <li><a href="@AppRoutes.ShopQuery.Sort("new")"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Shopping.NewArrivals"]</a>
          </li>
          <li><a href="@AppRoutes.ShopQuery.Sort("bestseller")"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Shopping.Bestsellers"]</a>
          </li>
          <li><a href="@AppRoutes.ShopQuery.Sale()"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Shopping.OnSale"]</a>
          </li>
        </ul>
      </div>

      <div>
        <h4
          class="text-[11px] font-bold text-cream-100 mb-4 uppercase tracking-[0.12em]">@SharedLocalizer["Footer.Selling"]</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="@AppRoutes.Seller.Dashboard"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Selling.SellerChannel"]</a>
          </li>
          <li><a href="@AppRoutes.Auth.RegisterSeller"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Selling.RegisterSeller"]</a>
          </li>
          <li><a href="#"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Selling.CommissionPolicy"]</a>
          </li>
          <li><a href="#"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Selling.SellerGuide"]</a>
          </li>
        </ul>
      </div>

      <div>
        <h4
          class="text-[11px] font-bold text-cream-100 mb-4 uppercase tracking-[0.12em]">@SharedLocalizer["Footer.Support"]</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="#"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Support.HelpCenter"]</a>
          </li>
          <li><a href="#"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Support.ReturnPolicy"]</a>
          </li>
          <li><a href="@AppRoutes.Account.Disputes"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Support.Disputes"]</a>
          </li>
          <li><a href="mailto:support@marketnest.vn"
                 class="text-cream-400 hover:text-cream-100 transition-colors">@SharedLocalizer["Footer.Support.Contact"]</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-cream-500">
        <span>&copy; @DateTime.UtcNow.Year @AppConstants.AppName. @SharedLocalizer["Footer.Copyright"]</span>
        <div class="flex items-center gap-4">
          <a href="#" class="hover:text-cream-200 transition-colors">@SharedLocalizer["Footer.Terms"]</a>
          <a href="#" class="hover:text-cream-200 transition-colors">@SharedLocalizer["Footer.Privacy"]</a>
          <a href="#" class="hover:text-cream-200 transition-colors">@SharedLocalizer["Footer.Cookies"]</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- ░░ TOAST NOTIFICATIONS ░░ -->
<div class="fixed bottom-5 right-5 z-[9999] flex flex-col gap-2.5 max-w-sm w-full pointer-events-none"
     x-data x-cloak>
  <template x-for="toast in $store.toasts.items" :key="toast.id">
    <div x-show="toast.visible"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-4 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-end="opacity-0 translate-y-2 scale-95"
         :class="{
                     'border-success-300 bg-success-50 text-success-700': toast.type === 'success',
                     'border-danger-300 bg-danger-50 text-danger-700':    toast.type === 'error',
                     'border-warn-300 bg-warn-50 text-warn-700':          toast.type === 'warning',
                     'border-info-300 bg-info-50 text-info-700':          toast.type === 'info'
                 }"
         class="pointer-events-auto flex items-start gap-3 px-4 py-3.5
                        rounded-2xl border shadow-lg backdrop-blur-sm">
      <span x-text="toast.message" class="text-sm font-medium flex-1"></span>
      <button @@click="$store.toasts.dismiss(toast.id)"
              class="opacity-40 hover:opacity-100 transition-opacity text-lg leading-none -mt-0.5">
        &times;
      </button>
    </div>
  </template>
</div>

<script>
  document.addEventListener('showToast', function (e) {
    const {message, type} = e.detail ?? {};
    if (message && window.Alpine) Alpine.store('toasts').show(message, type ?? 'info');
  });
</script>

@await RenderSectionAsync("Scripts", false)
</body>

</html>
