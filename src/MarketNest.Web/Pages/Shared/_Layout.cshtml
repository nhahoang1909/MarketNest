@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
  var requestToken = Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] - MarketNest</title>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>

  @* HTMX configuration: outerHTML swap, view transitions, CSRF header *@
  <meta name="htmx-config"
        content='{"defaultSwapStyle":"outerHTML","globalViewTransitions":true,"getCacheBusterParam":true}'>
  <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>

  @* Alpine.js — loaded before Alpine components *@
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  @* Alpine stores (global state) *@
  <script src="~/js/stores/toastStore.js" defer></script>
  <script src="~/js/stores/cartStore.js" defer></script>
  <script src="~/js/stores/authStore.js" defer></script>

  @* Alpine components *@
  <script src="~/js/components/searchBar.js" defer></script>

  @* App bootstrap + HTMX helpers *@
  <script src="~/js/magic/htmxHelpers.js" defer></script>
  <script src="~/js/app.js" defer></script>
</head>

<body class="min-h-screen flex flex-col" x-data>
@* CSRF token for HTMX requests *@
<input type="hidden" name="__RequestVerificationToken" value="@requestToken.RequestToken"/>

<!-- Top Bar -->
<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <a href="/" class="text-2xl font-bold text-brand-500">MarketNest</a>

      @* Search bar (Alpine component) *@
      <div class="hidden md:block flex-1 max-w-lg mx-8" x-data="searchBar()" x-cloak>
        <form action="/search" method="get" class="relative">
          <input type="text" name="q" x-model="query" placeholder="Search products..." class="w-full rounded-lg border border-gray-300 px-4 py-2 pr-10
                        focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                 hx-get="/search/suggestions" hx-trigger="keyup changed delay:300ms"
                 hx-target="#search-suggestions"/>
          <div id="search-suggestions"
               class="absolute top-full left-0 right-0 bg-white shadow-lg rounded-b-lg z-50">
          </div>
        </form>
      </div>

      <nav class="flex items-center gap-4">
        @* Cart indicator with live count *@
        <a href="/cart" class="relative text-gray-600 hover:text-brand-500" x-data x-text="'Cart'"
           :class="{ 'font-semibold': $store.cart.count > 0 }">
          Cart
          <template x-if="$store.cart.count > 0">
                            <span class="absolute -top-2 -right-3 bg-brand-500 text-white text-xs
                            rounded-full w-5 h-5 flex items-center justify-center"
                                  x-text="$store.cart.count"></span>
          </template>
        </a>

        @* Auth state — show login or account menu *@
        <template x-if="!$store.auth.isLoggedIn">
          <a href="/auth/login" class="text-gray-600 hover:text-brand-500">Login</a>
        </template>
        <template x-if="$store.auth.isLoggedIn">
          <div x-data="{ open: false }" class="relative">
            <button @@click="open = !open"
                    class="text-gray-600 hover:text-brand-500 flex items-center gap-1">
              <span x-text="$store.auth.displayName"></span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div x-show="open" @@click.away="open = false" x-cloak
                 class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border z-50">
              <a href="/account/settings" class="block px-4 py-2 text-sm hover:bg-gray-50">Account</a>
              <a href="/account/orders" class="block px-4 py-2 text-sm hover:bg-gray-50">My Orders</a>
              <a href="/seller/dashboard" class="block px-4 py-2 text-sm hover:bg-gray-50">Seller
                Dashboard</a>
              <hr class="my-1"/>
              <button @@click="$store.auth.logout()"
                      class="block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-50">
                Logout
              </button>
            </div>
          </div>
        </template>
      </nav>
    </div>
  </div>
</header>

<!-- Main Content -->
<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
  @RenderBody()
</main>

<!-- Footer -->
<footer class="bg-gray-50 border-t border-gray-200 py-8">
  <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
    &copy; @DateTime.UtcNow.Year MarketNest. Built as a learning project.
  </div>
</footer>

@* Toast notification container (Alpine $store.toast) *@
<div class="fixed bottom-4 right-4 z-[9999] flex flex-col gap-2" x-data x-cloak>
  <template x-for="toast in $store.toast.items" :key="toast.id">
    <div x-show="toast.visible" x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 translate-y-2"
         :class="{
                    'bg-green-50 border-green-400 text-green-800': toast.type === 'success',
                    'bg-red-50 border-red-400 text-red-800': toast.type === 'error',
                    'bg-yellow-50 border-yellow-400 text-yellow-800': toast.type === 'warning',
                    'bg-blue-50 border-blue-400 text-blue-800': toast.type === 'info'
                    }" class="px-4 py-3 rounded-lg border shadow-lg max-w-sm">
      <div class="flex items-center justify-between gap-2">
        <span x-text="toast.message" class="text-sm"></span>
        <button @@click="$store.toast.dismiss(toast.id)"
                class="text-current opacity-50 hover:opacity-100">&times;
        </button>
      </div>
    </div>
  </template>
</div>

@* HTMX event → toast bridge: listen for HX-Trigger showToast *@
<script>
  document.addEventListener('showToast', function (e) {
    const {message, type} = e.detail ?? {};
    if (message && window.Alpine) {
      Alpine.store('toast').show(message, type ?? 'info');
    }
  });
</script>

@await RenderSectionAsync("Scripts", false)
</body>

</html>
