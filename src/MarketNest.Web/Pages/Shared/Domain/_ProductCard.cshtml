@* Product card — used in search results and storefront grids *@
@{
  var imageUrl = ViewData["ImageUrl"]?.ToString() ?? "/img/placeholder-product.svg";
  var title = ViewData["Title"]?.ToString() ?? "Product";
  var storeName = ViewData["StoreName"]?.ToString() ?? "";
  var price = ViewData["Price"]?.ToString() ?? "0.00";
  var compareAtPrice = ViewData["CompareAtPrice"]?.ToString();
  var rating = ViewData["Rating"]?.ToString() ?? "0";
  var productUrl = ViewData["ProductUrl"]?.ToString() ?? "#";
  var currency = ViewData["Currency"]?.ToString() ?? "$";
}

<a href="@productUrl" class="card group hover:shadow-md transition-shadow block">
  <div class="aspect-square overflow-hidden rounded-t-xl bg-gray-100">
    <img src="@imageUrl" alt="@title" width="400" height="400"
         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy"/>
  </div>
  <div class="card-body">
    <h3 class="font-medium text-gray-900 truncate">@title</h3>
    <p class="text-sm text-gray-500 truncate">@storeName</p>
    <div class="flex items-center justify-between mt-2">
      <div class="flex items-center gap-1.5">
        <span class="text-lg font-bold text-brand-600">@currency@price</span>
        @if (!string.IsNullOrEmpty(compareAtPrice))
        {
          <span class="text-xs text-gray-400 line-through">@currency@compareAtPrice</span>
        }
      </div>
      <div class="flex items-center gap-1 text-sm text-gray-500">
        <span class="text-yellow-400">★</span>
        <span>@rating</span>
      </div>
    </div>
  </div>
</a>
