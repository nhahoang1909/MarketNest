@* Breadcrumb — pass Items (List<(string Label, string Url)>) via ViewData *@
@{
    var items = ViewData["Items"] as IEnumerable<(string Label, string Url)>
        ?? Enumerable.Empty<(string Label, string Url)>();
    var itemList = items.ToList();
}

<nav aria-label="Breadcrumb" class="mb-4">
    <ol class="flex items-center gap-1.5 text-sm text-gray-500">
        <li>
            <a href="/" class="hover:text-gray-700">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd"
                          d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z"
                          clip-rule="evenodd" />
                </svg>
            </a>
        </li>
        @for (var i = 0; i < itemList.Count; i++)
        {
            <li class="flex items-center gap-1.5">
                <svg class="h-4 w-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                          d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                          clip-rule="evenodd" />
                </svg>
                @if (i == itemList.Count - 1)
                {
                    <span class="font-medium text-gray-900">@itemList[i].Label</span>
                }
                else
                {
                    <a href="@itemList[i].Url" class="hover:text-gray-700">@itemList[i].Label</a>
                }
            </li>
        }
    </ol>
</nav>
