@* Alert block — pass Type (info/success/warning/error), Message, Dismissible via ViewData *@
@{
  var type = ViewData["Type"]?.ToString() ?? "info";
  var message = ViewData["Message"]?.ToString() ?? "";
  var dismissible = ViewData["Dismissible"]?.ToString() == "true";
  var (bgCss, iconCss, textCss, borderCss) = type switch
  {
    "success" => ("bg-green-50", "text-green-400", "text-green-800", "border-green-200"),
    "warning" => ("bg-yellow-50", "text-yellow-400", "text-yellow-800", "border-yellow-200"),
    "error" => ("bg-red-50", "text-red-400", "text-red-800", "border-red-200"),
    _ => ("bg-blue-50", "text-blue-400", "text-blue-800", "border-blue-200")
  };
  var iconPath = type switch
  {
    "success" => "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    "warning" => "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z",
    "error" => "M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    _ => "M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
  };
}

@if (!string.IsNullOrEmpty(message))
{
  <div class="rounded-lg border @borderCss @bgCss p-4" x-data="{ show: true }" x-show="show" x-transition>
    <div class="flex">
      <svg class="h-5 w-5 @iconCss flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="@iconPath"/>
      </svg>
      <p class="ml-3 text-sm @textCss">@message</p>
      @if (dismissible)
      {
        <button type="button" @@click="show = false"
                class="ml-auto -mx-1.5 -my-1.5 rounded-lg p-1 @textCss hover:opacity-75 focus:outline-none">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd"
                  d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                  clip-rule="evenodd"/>
          </svg>
        </button>
      }
    </div>
  </div>
}
