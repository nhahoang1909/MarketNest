@* Interactive star rating input — pass Name, Value via ViewData *@
@{
    var name = ViewData["Name"]?.ToString() ?? "rating";
    var value = ViewData["Value"]?.ToString() ?? "0";
}

<div x-data="starRating({ value: @value })" class="inline-flex items-center gap-1">
    <input type="hidden" name="@name" :value="value" />
    <template x-for="star in 5" :key="star">
        <button type="button" @@mouseenter="setHover(star)" @@mouseleave="clearHover()" @@click="select(star)"
                class="focus:outline-none transition-colors">
            <svg class="h-6 w-6"
                 :class="(hover >= star || (!hover && value >= star)) ? 'text-yellow-400' : 'text-gray-300'"
                 fill="currentColor" viewBox="0 0 20 20">
                <path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.176 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.063 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" />
            </svg>
        </button>
    </template>
    <span class="ml-2 text-sm text-gray-500" x-text="value > 0 ? value + '/5' : ''"></span>
</div>
