@* Star rating display — pass Rating (double 0-5) via ViewData *@
@{
  var rating = double.TryParse(ViewData["Rating"]?.ToString(), out var r) ? r : 0;
  var fullStars = (int)Math.Floor(rating);
  var hasHalf = rating - fullStars >= 0.5;
  var emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
}

<div class="inline-flex items-center gap-0.5" aria-label="Rating: @rating out of 5">
  @for (var i = 0; i < fullStars; i++)
  {
    <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
      <path
        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.176 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.063 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z"/>
    </svg>
  }
  @if (hasHalf)
  {
    <svg class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20">
      <defs>
        <linearGradient id="halfStar">
          <stop offset="50%" stop-color="currentColor"/>
          <stop offset="50%" stop-color="#D1D5DB"/>
        </linearGradient>
      </defs>
      <path fill="url(#halfStar)"
            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.176 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.063 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z"/>
    </svg>
  }
  @for (var i = 0; i < emptyStars; i++)
  {
    <svg class="h-4 w-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
      <path
        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.176 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.063 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z"/>
    </svg>
  }
  <span class="ml-1 text-sm text-gray-600">@rating.ToString("0.#")</span>
</div>
