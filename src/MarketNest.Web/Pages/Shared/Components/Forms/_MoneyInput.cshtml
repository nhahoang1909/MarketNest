@* Money input — pass Label, Name, Value, Currency, Errors via ViewData *@
@{
    var label = ViewData["Label"]?.ToString() ?? "Price";
    var name = ViewData["Name"]?.ToString() ?? "price";
    var value = ViewData["Value"]?.ToString() ?? "";
    var currency = ViewData["Currency"]?.ToString() ?? "$";
    var errors = ViewData["Errors"] as IEnumerable<string>;
    var hasError = errors?.Any() == true;
    var inputCss = hasError ? "form-input input-error pl-8" : "form-input pl-8";
}

<div class="space-y-1">
    <label for="@name" class="form-label">@label</label>
    <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 font-medium">
            @currency
        </span>
        <input type="number" id="@name" name="@name" value="@value" step="0.01" min="0" placeholder="0.00"
               class="@inputCss" inputmode="decimal" />
    </div>
    @if (hasError)
    {
        @foreach (var error in errors!)
        {
            <p class="form-error">@error</p>
        }
    }
</div>
