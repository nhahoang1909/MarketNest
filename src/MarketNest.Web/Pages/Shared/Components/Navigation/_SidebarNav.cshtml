@* Sidebar nav item — pass Label, Url, Icon, IsActive via ViewData *@
@{
    var label = ViewData["Label"]?.ToString() ?? "Link";
    var url = ViewData["Url"]?.ToString() ?? "#";
    var iconPath = ViewData["Icon"]?.ToString() ?? "M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25";
    var isActive = ViewData["IsActive"]?.ToString() == "true";
    var linkCss = isActive ? "sidebar-link-active" : "sidebar-link";
}

<a href="@url" class="@linkCss">
    <svg class="h-5 w-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
         stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="@iconPath" />
    </svg>
    <span>@label</span>
</a>
