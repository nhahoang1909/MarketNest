@page "/not-found"
@model MarketNest.Web.Pages.NotFoundModel
@{
  // Route attributes do not belong inside a Razor code block. Use @page for Razor Pages.
  Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>@AppConstants.NotFoundPage.PageTitle</title>

  <!-- Fonts -->
  <link rel="preconnect" href="@AppConstants.Fonts.GoogleFontsOrigin"/>
  <link rel="preconnect" href="@AppConstants.Fonts.GoogleFontsStaticOrigin" crossorigin/>
  <link href="@AppConstants.Fonts.DisplayCdn" rel="stylesheet"/>
  <link href="@AppConstants.Fonts.SansCdn" rel="stylesheet"/>
  <link href="@AppConstants.Fonts.MonoCdn" rel="stylesheet"/>

  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  <style>
    /* ─────────── Page scaffolding ─────────── */
    .nf-page {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: 24px 40px 28px;
      background: var(--color-cream-100);
      color: var(--color-ink-800);
      font-family: var(--font-sans), sans-serif;
    }

    /* Header bar */
    .nf-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(30, 57, 50, 0.08);
    }

    .nf-brand {
      display: inline-flex;
      align-items: baseline;
      gap: 4px;
      text-decoration: none;
      color: inherit;
    }

    .nf-brand-mark {
      width: 26px;
      height: 26px;
      border-radius: 8px;
      background: var(--color-ink-800);
      color: var(--color-cream-100);
      display: inline-grid;
      place-items: center;
      font-family: var(--font-display), serif;
      font-size: 17px;
      font-weight: 500;
      transform: translateY(2px);
    }

    .nf-brand-word {
      font-family: var(--font-display), serif;
      font-size: 22px;
      font-weight: 500;
      letter-spacing: -0.02em;
    }

    .nf-crumbs {
      font-family: var(--font-mono), monospace;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(30, 57, 50, 0.42);
    }

    .nf-crumbs .slash {
      padding: 0 8px;
      opacity: 0.5;
    }

    .nf-crumbs .err {
      color: var(--color-danger-500);
    }

    /* ─────────── Hero ─────────── */
    .nf-hero-wrap {
      display: grid;
      place-items: center;
      padding: 40px 0;
    }

    .nf-hero {
      width: 100%;
      max-width: 1100px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 28px;
      justify-items: center;
      text-align: center;
    }

    /* The 404 wordmark — massive, globe replaces zero.
       font-family intentionally NOT SET here — inherits DM Sans from body.
       Playfair Display at clamp(180px,28vw,360px) has broken ink-box metrics
       that misplace the glyph far outside its CSS layout box, breaking
       grid-based vertical centering. DM Sans has correct metrics at all sizes. */
    .nf-wordmark {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: clamp(8px, 1.4vw, 18px);
      width: 100%;
      font-weight: 300;
      line-height: 0.85;
      letter-spacing: -0.045em;
      color: var(--color-ink-800);
      font-size: clamp(180px, 28vw, 360px);
      user-select: none;
    }

    /* Left "4" — pushed toward the globe */
    .nf-wordmark > .nf-digit:first-child {
      justify-self: end;
      transform: translateY(0.02em);
    }

    /* Right "4" — pushed toward the globe */
    .nf-wordmark > .nf-digit:last-child {
      justify-self: start;
      transform: translateY(0.02em);
    }

    .nf-digit {
      transform: translateY(0.02em);
    }

    /* Globe stage — auto column, sized to cap-height of digits */
    .nf-globe-stage {
      position: relative;
      width: clamp(160px, 24vw, 300px);
      height: clamp(160px, 24vw, 300px);
      flex-shrink: 0;
      transform: translateY(2%);
      cursor: grab;
      touch-action: none;
    }

    .nf-globe-stage.dragging {
      cursor: grabbing;
    }

    .nf-globe-stage.dragging .nf-halo {
      animation-play-state: paused;
      opacity: 0.85;
    }

    .nf-globe-stage svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    /* Drag hint */
    .nf-drag-hint {
      position: absolute;
      left: 50%;
      bottom: -34px;
      transform: translateX(-50%);
      font-family: var(--font-mono), monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(30, 57, 50, 0.42);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .nf-drag-hint-icon {
      width: 14px;
      height: 14px;
      border: 1px solid currentColor;
      border-radius: 50%;
      display: inline-grid;
      place-items: center;
      font-size: 9px;
    }

    .nf-globe-stage:hover .nf-drag-hint {
      opacity: 1;
    }

    .nf-globe-stage.has-dragged .nf-drag-hint {
      opacity: 0 !important;
    }

    /* Soft halo behind globe */
    .nf-halo {
      position: absolute;
      inset: -8%;
      border-radius: 50%;
      background: radial-gradient(closest-side,
        rgba(0, 117, 74, 0.18),
        rgba(0, 117, 74, 0.06) 55%,
        transparent 72%);
      filter: blur(6px);
      animation: nf-haloPulse 4.6s ease-in-out infinite;
    }

    /* Globe sphere */
    .globe-sphere {
      fill: var(--color-cream-100);
      stroke: var(--color-ink-800);
      stroke-width: 1.1;
    }

    .globe-graticule {
      fill: none;
      stroke: var(--color-ink-800);
      stroke-width: 0.4;
      stroke-opacity: 0.28;
    }

    .globe-land {
      fill: var(--color-ink-800);
      fill-opacity: 0.92;
      stroke: var(--color-ink-800);
      stroke-width: 0.25;
      stroke-linejoin: round;
    }

    /* Lost pin marker */
    .lost-pin {
      transform-origin: 100px 100px;
      animation: nf-pinFlicker 2.4s steps(1, end) infinite;
    }

    .lost-pin .pin-glow {
      fill: var(--color-danger-500);
      fill-opacity: 0.35;
      animation: nf-pinPing 2.4s ease-out infinite;
      transform-origin: center;
      transform-box: fill-box;
    }

    .lost-pin .pin-core {
      fill: var(--color-danger-500);
    }

    /* Orbit rings */
    .whirl, .whirl-rev, .whirl-fast {
      transform-origin: 100px 100px;
    }

    .whirl {
      animation: nf-spin 9s linear infinite;
    }

    .whirl-rev {
      animation: nf-spinRev 14s linear infinite;
    }

    .whirl-fast {
      animation: nf-spin 6s linear infinite;
    }

    .nf-arc {
      fill: none;
      stroke: var(--color-ink-800);
      stroke-linecap: round;
    }

    .nf-dot {
      fill: var(--color-ink-800);
    }

    .nf-dot-accent {
      fill: var(--color-accent-400);
      stroke: var(--color-ink-800);
      stroke-width: 0.6;
    }

    /* Search beam — comet-tail */
    .nf-beam {
      fill: none;
      stroke: var(--color-accent-400);
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-dasharray: 26 480;
      animation: nf-beamRun 3.6s linear infinite;
      filter: drop-shadow(0 0 4px rgba(0, 117, 74, 0.5));
    }

    /* Ground shadow under globe */
    .nf-ground-shadow {
      position: absolute;
      left: 8%;
      right: 8%;
      bottom: -2%;
      height: 14px;
      background: radial-gradient(ellipse at center, rgba(30, 57, 50, 0.22), transparent 70%);
      filter: blur(2px);
    }

    /* ─────────── Meta strip ─────────── */
    .nf-meta-strip {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--color-surface);
      border: 1px solid rgba(30, 57, 50, 0.08);
      font-family: var(--font-mono), monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(30, 57, 50, 0.62);
      margin-top: 8px;
    }

    .nf-meta-strip .nf-pulse {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-danger-500);
      box-shadow: 0 0 0 0 rgba(200, 32, 20, 0.7);
      animation: nf-dotPulse 1.6s ease-out infinite;
    }

    .nf-meta-strip .nf-sep {
      width: 1px;
      height: 12px;
      background: rgba(30, 57, 50, 0.14);
    }

    .nf-meta-strip .nf-coord {
      color: var(--color-ink-800);
    }

    /* ─────────── Copy block ─────────── */
    .nf-copy h2 {
      font-family: var(--font-display), serif;
      font-weight: 400;
      font-size: clamp(28px, 3.6vw, 44px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 18px 0 10px;
      text-wrap: balance;
    }

    .nf-copy p {
      font-size: 16px;
      line-height: 1.55;
      color: rgba(30, 57, 50, 0.62);
      max-width: 48ch;
      margin: 0 auto 24px;
      text-wrap: pretty;
    }

    .nf-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nf-btn {
      appearance: none;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 24px;
      border-radius: 999px;
      font: inherit;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: -0.005em;
      cursor: pointer;
      text-decoration: none;
      white-space: nowrap;
      transition: all 0.2s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .nf-btn-primary {
      background: var(--color-accent-400);
      color: #fff;
      border: 1px solid var(--color-accent-400);
    }

    .nf-btn-primary:hover {
      background: var(--color-accent-500);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(0, 117, 74, 0.25);
    }

    .nf-btn-ghost {
      background: transparent;
      color: var(--color-ink-800);
      border: 1px solid rgba(30, 57, 50, 0.22);
    }

    .nf-btn-ghost:hover {
      background: var(--color-surface-inset);
      border-color: rgba(30, 57, 50, 0.35);
      transform: translateY(-1px);
    }

    .nf-btn .nf-arrow {
      display: inline-block;
      transition: transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .nf-btn:hover .nf-arrow {
      transform: translateX(3px);
    }

    /* ─────────── Suggested destinations ─────────── */
    .nf-suggested {
      margin-top: 36px;
      width: 100%;
      max-width: 720px;
      border-top: 1px solid rgba(30, 57, 50, 0.08);
      padding-top: 20px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      text-align: left;
    }

    .nf-sug-card {
      padding: 14px 16px;
      border: 1px solid rgba(30, 57, 50, 0.08);
      border-radius: 14px;
      background: var(--color-surface);
      transition: border-color 0.2s cubic-bezier(0.22, 0.61, 0.36, 1),
                  transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      text-decoration: none;
      color: inherit;
    }

    .nf-sug-card:hover {
      border-color: var(--color-ink-800);
      transform: translateY(-1px);
    }

    .nf-sug-label {
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(30, 57, 50, 0.62);
      margin-bottom: 4px;
    }

    .nf-sug-title {
      font-family: var(--font-display), serif;
      font-size: 18px;
      letter-spacing: -0.01em;
    }

    .nf-sug-arrow {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      background: var(--color-surface-inset);
      display: grid;
      place-items: center;
      flex-shrink: 0;
      transition: background 0.2s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .nf-sug-card:hover .nf-sug-arrow {
      background: var(--color-accent-400);
      color: #fff;
    }

    /* ─────────── Footer ─────────── */
    .nf-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(30, 57, 50, 0.08);
      padding-top: 18px;
      font-family: var(--font-mono), monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(30, 57, 50, 0.42);
    }

    .nf-footer-signal {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .nf-footer-blip {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-warn-500);
      animation: nf-blink 1.4s ease-in-out infinite;
    }

    /* ─────────── Keyframes ─────────── */
    @@keyframes nf-haloPulse {
      0%, 100% { opacity: 0.55; transform: scale(0.96); }
      50%      { opacity: 1;    transform: scale(1.04); }
    }

    @@keyframes nf-pinFlicker {
      0%, 38%, 56%, 100% { opacity: 1; }
      40%, 44%           { opacity: 0.15; }
      58%, 64%           { opacity: 0.35; }
    }

    @@keyframes nf-pinPing {
      0%   { transform: scale(1);     fill-opacity: 0.55; }
      100% { transform: scale(5.625); fill-opacity: 0;    }
    }

    @@keyframes nf-spin {
      to { transform: rotate(360deg); }
    }

    @@keyframes nf-spinRev {
      to { transform: rotate(-360deg); }
    }

    @@keyframes nf-beamRun {
      0%   { stroke-dashoffset: 0; }
      100% { stroke-dashoffset: -506; }
    }

    @@keyframes nf-dotPulse {
      0%   { box-shadow: 0 0 0 0 rgba(200, 32, 20, 0.6); }
      70%  { box-shadow: 0 0 0 8px rgba(200, 32, 20, 0); }
      100% { box-shadow: 0 0 0 0 rgba(200, 32, 20, 0); }
    }

    @@keyframes nf-blink {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.25; }
    }

    /* ─────────── Responsive ─────────── */
    @@media (max-width: 720px) {
      .nf-page {
        padding: 18px 20px 20px;
      }

      .nf-wordmark {
        font-size: clamp(80px, 24vw, 180px);
        column-gap: clamp(4px, 1vw, 10px);
      }

      .nf-globe-stage {
        width: clamp(70px, 20vw, 160px);
        height: clamp(70px, 20vw, 160px);
      }

      .nf-suggested {
        grid-template-columns: 1fr;
      }

      .nf-crumbs {
        display: none;
      }
    }

    /* ─────────── Reduced motion ─────────── */
    @@media (prefers-reduced-motion: reduce) {
      .whirl, .whirl-rev, .whirl-fast,
      .nf-halo, .lost-pin, .lost-pin .pin-glow,
      .nf-beam, .nf-meta-strip .nf-pulse,
      .nf-footer-blip {
        animation: none !important;
      }
    }
  </style>
</head>
<body>
<div class="nf-page">

  <!-- Header -->
  <header class="nf-header">
    <a href="@AppRoutes.Home" class="nf-brand">
      <span class="nf-brand-mark">m</span>
      <span class="nf-brand-word">@AppConstants.AppName</span>
    </a>
    <div class="nf-crumbs">
      <span>Home</span>
      <span class="slash">/</span>
      <span>Search</span>
      <span class="slash">/</span>
      <span class="err">@AppConstants.NotFoundPage.BreadcrumbError</span>
    </div>
  </header>

  <!-- Hero -->
  <main class="nf-hero-wrap">
    <div class="nf-hero">

      <!-- 4 • globe • 4 -->
      <div class="nf-wordmark" aria-label="404">
        <span class="nf-digit">4</span>

        <span class="nf-globe-stage" id="globe-stage" role="img" aria-label="Spinning globe replacing the zero">
          <span class="nf-halo"></span>

          <!-- Orbit rings + comet beam -->
          <svg viewBox="0 0 200 200" aria-hidden="true">
            <g class="whirl-rev">
              <circle cx="100" cy="100" r="96" class="nf-arc"
                      stroke-width="1" stroke-opacity="0.35"
                      stroke-dasharray="140 80 28 360"/>
              <circle cx="100" cy="100" r="96" class="nf-arc"
                      stroke-width="1" stroke-opacity="0.12"
                      stroke-dasharray="2 6"/>
              <circle class="nf-dot-accent" cx="196" cy="100" r="3"/>
              <circle class="nf-dot" cx="4" cy="100" r="1.6" fill-opacity="0.55"/>
            </g>
            <g class="whirl">
              <circle cx="100" cy="100" r="88" class="nf-arc"
                      stroke-width="0.8" stroke-opacity="0.7"
                      stroke-dasharray="60 22 14 30 6 360"/>
            </g>
            <g class="whirl-fast">
              <circle cx="100" cy="100" r="80.5" class="nf-beam" pathLength="506"/>
            </g>
          </svg>

          <!-- Globe -->
          <svg viewBox="0 0 200 200" id="globe">
            <defs>
              <radialGradient id="globeShade" cx="38%" cy="32%" r="78%">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="0.55"/>
                <stop offset="55%" stop-color="#ffffff" stop-opacity="0"/>
                <stop offset="100%" stop-color="#000000" stop-opacity="0.18"/>
              </radialGradient>
              <clipPath id="globeClip">
                <circle cx="100" cy="100" r="74"/>
              </clipPath>
            </defs>

            <circle class="globe-sphere" cx="100" cy="100" r="74"/>
            <g clip-path="url(#globeClip)">
              <path class="globe-graticule" id="graticule-path"/>
              <path class="globe-land" id="land-path"/>

              <!-- "Missing location" flickering pin -->
              <g class="lost-pin">
                <circle class="pin-glow" cx="100" cy="106" r="1.6"/>
                <circle class="pin-core" cx="100" cy="106" r="2.2"/>
                <line x1="100" y1="106" x2="100" y2="100"
                      stroke="var(--color-danger-500)" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="100" cy="100" r="1.4" fill="var(--color-danger-500)"/>
              </g>
            </g>

            <!-- Spherical sheen -->
            <circle cx="100" cy="100" r="74" fill="url(#globeShade)"/>
          </svg>

          <!-- Baseline shadow -->
          <span class="nf-ground-shadow"></span>

          <!-- Drag affordance -->
          <span class="nf-drag-hint" id="dragHint">
            <span class="nf-drag-hint-icon">↕</span>
            <span>@AppConstants.NotFoundPage.DragHint</span>
          </span>
        </span>

        <span class="nf-digit">4</span>
      </div>

      <!-- Live coordinate ticker -->
      <div class="nf-meta-strip" aria-live="polite">
        <span class="nf-pulse"></span>
        <span>@AppConstants.NotFoundPage.SignalLost</span>
        <span class="nf-sep"></span>
        <span class="nf-coord" id="coord">@AppConstants.NotFoundPage.CoordinateFormat</span>
        <span class="nf-sep"></span>
        <span>@AppConstants.NotFoundPage.TraceId</span>
      </div>

      <!-- Copy -->
      <div class="nf-copy">
        <h2>@AppConstants.NotFoundPage.Heading</h2>
        <p>@AppConstants.NotFoundPage.Description</p>

        <div class="nf-actions">
          <a href="@AppRoutes.Home" class="nf-btn nf-btn-primary">
            @AppConstants.NotFoundPage.BackToHome <span class="nf-arrow">→</span>
          </a>
          <a href="@AppRoutes.Home" class="nf-btn nf-btn-ghost">
            @AppConstants.NotFoundPage.BrowseShop
          </a>
        </div>
      </div>

      <!-- Suggested destinations -->
      <nav class="nf-suggested" aria-label="Suggested destinations">
        <a href="@AppRoutes.Shop" class="nf-sug-card">
          <div>
            <div class="nf-sug-label">@AppConstants.NotFoundPage.SugBrowseLabel</div>
            <div class="nf-sug-title">@AppConstants.NotFoundPage.SugBrowseTitle</div>
          </div>
          <span class="nf-sug-arrow">→</span>
        </a>
        <a href="@AppRoutes.Account.Orders" class="nf-sug-card">
          <div>
            <div class="nf-sug-label">@AppConstants.NotFoundPage.SugAccountLabel</div>
            <div class="nf-sug-title">@AppConstants.NotFoundPage.SugAccountTitle</div>
          </div>
          <span class="nf-sug-arrow">→</span>
        </a>
        <a href="@AppRoutes.Seller.Dashboard" class="nf-sug-card">
          <div>
            <div class="nf-sug-label">@AppConstants.NotFoundPage.SugHelpLabel</div>
            <div class="nf-sug-title">@AppConstants.NotFoundPage.SugHelpTitle</div>
          </div>
          <span class="nf-sug-arrow">→</span>
        </a>
      </nav>

    </div>
  </main>

  <!-- Footer -->
  <footer class="nf-footer">
    <div>© @AppConstants.CopyrightYear @AppConstants.AppName</div>
    <div class="nf-footer-signal">
      <span class="nf-footer-blip"></span>
      <span>@AppConstants.NotFoundPage.FooterStatus</span>
    </div>
  </footer>

</div>

<script src="@AppConstants.Cdn.D3Js"></script>
<script src="@AppConstants.Cdn.TopojsonClient"></script>
<script>
  (async () => {
    const W = 200, H = 200, R = 74;
    const projection = d3.geoOrthographic()
      .scale(R)
      .translate([W / 2, H / 2])
      .clipAngle(90)
      .rotate([0, -14, 0]);
    const path = d3.geoPath(projection);
    const graticule = d3.geoGraticule10();

    const landEl  = document.getElementById('land-path');
    const gratEl  = document.getElementById('graticule-path');
    const coordEl = document.getElementById('coord');
    const stageEl = document.getElementById('globe-stage');

    let land = null;
    try {
      const res = await fetch('@AppConstants.Cdn.WorldAtlas');
      const topo = await res.json();
      land = topojson.feature(topo, topo.objects.countries);
    } catch (e) {
      console.warn('world-atlas fetch failed', e);
    }

    function draw() {
      gratEl.setAttribute('d', path(graticule) || '');
      if (land) landEl.setAttribute('d', path(land) || '');
    }
    draw();

    // ─── State ──────────────────────────────────────────────
    let mode = 'auto';
    let lambda = 0;
    let phi = -14;
    const PHI_MIN = -75, PHI_MAX = 75;

    const AUTO_SPEED = 360 / 28000;
    let autoBaseLambda = 0;
    let autoStart = performance.now();

    let pointerId = null;
    let lastX = 0, lastY = 0, lastT = 0;
    let velX = 0, velY = 0;

    function degPerPx() {
      const rect = stageEl.getBoundingClientRect();
      const screenR = (rect.width * 74) / 200;
      return 90 / Math.max(1, screenR);
    }

    function fmt(v, pad) {
      const s = Math.abs(v).toFixed(1).padStart(pad, '0');
      return (v < 0 ? '-' : ' ') + s + '\u00B0';
    }

    function applyRotation() {
      projection.rotate([lambda, phi, 0]);
      draw();
      const lon = ((lambda + 180) % 360 + 360) % 360 - 180;
      const lat = -phi;
      coordEl.textContent =
        'LAT ' + fmt(lat, 4) + ' \u00B7 LON ' + fmt(lon, 5);
    }

    // ─── Pointer handlers (drag to spin) ────────────────────
    stageEl.addEventListener('pointerdown', (e) => {
      if (pointerId !== null) return;
      pointerId = e.pointerId;
      stageEl.setPointerCapture(pointerId);
      stageEl.classList.add('dragging', 'has-dragged');
      mode = 'drag';
      lastX = e.clientX; lastY = e.clientY;
      lastT = performance.now();
      velX = 0; velY = 0;
      e.preventDefault();
    });

    stageEl.addEventListener('pointermove', (e) => {
      if (e.pointerId !== pointerId || mode !== 'drag') return;
      const now = performance.now();
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      const dt = Math.max(1, now - lastT);
      const k = degPerPx();

      const dLam = dx * k;
      const dPhi = -dy * k;

      lambda += dLam;
      phi = Math.max(PHI_MIN, Math.min(PHI_MAX, phi + dPhi));
      applyRotation();

      // EMA velocity for momentum on release
      const instVx = dLam / dt;
      const instVy = dPhi / dt;
      velX = velX * 0.6 + instVx * 0.4;
      velY = velY * 0.6 + instVy * 0.4;

      lastX = e.clientX; lastY = e.clientY; lastT = now;
    });

    function endDrag(e) {
      if (e.pointerId !== pointerId) return;
      try { stageEl.releasePointerCapture(pointerId); } catch {}
      pointerId = null;
      stageEl.classList.remove('dragging');

      const speed = Math.hypot(velX, velY);
      if (speed > 0.02) {
        mode = 'coast';
      } else {
        resumeAuto();
      }
    }
    stageEl.addEventListener('pointerup', endDrag);
    stageEl.addEventListener('pointercancel', endDrag);

    function resumeAuto() {
      mode = 'auto';
      autoBaseLambda = lambda;
      autoStart = performance.now();
    }

    // ─── Main loop ──────────────────────────────────────────
    let prev = performance.now();
    function tick(now) {
      const dt = now - prev;
      prev = now;

      if (mode === 'auto') {
        lambda = autoBaseLambda + (now - autoStart) * AUTO_SPEED;
        phi = -14 + Math.sin(now / 4200) * 4;
        applyRotation();
      } else if (mode === 'coast') {
        const decay = Math.pow(0.0018, dt / 1000);
        velX *= decay;
        velY *= decay;
        lambda += velX * dt;
        phi = Math.max(PHI_MIN, Math.min(PHI_MAX, phi + velY * dt));
        applyRotation();
        if (Math.hypot(velX, velY) < 0.005) {
          resumeAuto();
        }
      }

      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    applyRotation();
  })();
</script>
</body>
</html>

