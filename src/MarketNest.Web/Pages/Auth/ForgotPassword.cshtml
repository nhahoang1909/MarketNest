@page "/auth/forgot-password"
@model MarketNest.Web.Pages.Auth.ForgotPasswordModel
@{
  ViewData["Title"] = I18N[I18NKeys.Page.ForgotPassword];
}

<section class="flex items-center justify-center min-h-[calc(100vh-200px)] py-12 px-4">
  <div class="w-full max-w-md">
    <div class="card">
      <div class="card-body space-y-6">

        <!-- Logo -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ink-700 flex items-center justify-center">
            <span class="text-accent-400 font-bold text-lg italic" style="font-family:'Fraunces',serif">m</span>
          </div>
          <span class="text-lg font-semibold text-ink-700 tracking-tight">@AppConstants.AppName</span>
        </div>

        <!-- Heading -->
        <div class="text-center space-y-2">
          <h1 class="mn-h4">@I18N[I18NKeys.Page.ForgotPassword]</h1>
          <p class="text-sm text-ink-400 leading-relaxed">
            @I18N[I18NKeys.Text.ForgotPasswordDescription]
          </p>
        </div>

        <!-- Form -->
        <form hx-post="@AppRoutes.Auth.ForgotPassword"
              hx-target="closest .card-body"
              hx-swap="innerHTML"
              hx-indicator="#forgot-spinner"
              class="space-y-4">
          @Html.AntiForgeryToken()

          <!-- Email -->
          <partial name="@SharedViewPaths.EmailField" view-data='@(new ViewDataDictionary(ViewData) {
              ["Label"]    = I18N[I18NKeys.Label.Email],
              ["Name"]     = "Email",
              ["Value"]    = "",
              ["Required"] = "true"
          })'/>

          <!-- Submit -->
          <button type="submit" class="btn-primary w-full">
            <span id="forgot-spinner" class="htmx-indicator">
              <svg class="animate-spin h-4 w-4 inline mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </span>
            @I18N[I18NKeys.Button.SendResetLink]
          </button>
        </form>

        <!-- Back to login -->
        <div class="text-center">
          <a href="@AppRoutes.Auth.Login"
             class="inline-flex items-center gap-1.5 text-sm font-medium text-ink-600 hover:text-ink-700 underline underline-offset-2 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
            @I18N[I18NKeys.Link.BackToLogin]
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
