@page "/auth/forgot-password"
@using MarketNest.Web.Infrastructure
@model ForgotPasswordModel
@{
  ViewData["Title"] = "Quen mat khau";
}

<section class="flex items-center justify-center min-h-[calc(100vh-200px)] py-12 px-4">
  <div class="w-full max-w-md">
    <div class="card">
      <div class="card-body space-y-6">

        <!-- Logo -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ink-700 flex items-center justify-center">
            <span class="text-accent-400 font-bold text-lg italic" style="font-family:'Fraunces',serif">m</span>
          </div>
          <span class="text-lg font-semibold text-ink-700 tracking-tight">@AppConstants.AppName</span>
        </div>

        <!-- Heading -->
        <div class="text-center space-y-2">
          <h1 class="mn-h4">Quen mat khau</h1>
          <p class="text-sm text-ink-400 leading-relaxed">
            Nhap dia chi email cua ban va chung toi se gui cho ban lien ket de dat lai mat khau.
          </p>
        </div>

        <!-- Form -->
        <form method="post" class="space-y-4">
          @Html.AntiForgeryToken()

          <!-- Email -->
          <div>
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="Email" placeholder="you@example.com" class="form-input" required />
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-primary w-full">
            Gui lien ket dat lai
          </button>
        </form>

        <!-- Back to login -->
        <div class="text-center">
          <a href="@AppRoutes.Auth.Login"
             class="inline-flex items-center gap-1.5 text-sm font-medium text-ink-600 hover:text-ink-700 underline underline-offset-2 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Quay lai dang nhap
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
