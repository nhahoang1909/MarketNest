@page "/auth/register"
@model MarketNest.Web.Pages.Auth.RegisterModel
@{
  ViewData["Title"] = I18N[I18NKeys.Page.Register];
}

<section class="flex items-center justify-center min-h-[calc(100vh-200px)] py-12 px-4">
  <div class="w-full max-w-md">
    <div class="card">
      <div class="card-body space-y-6">

        <!-- Logo -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ink-700 flex items-center justify-center">
            <span class="text-accent-400 font-bold text-lg italic" style="font-family:'Fraunces',serif">m</span>
          </div>
          <span class="text-lg font-semibold text-ink-700 tracking-tight">@AppConstants.AppName</span>
        </div>

        <!-- Heading -->
        <h1 class="mn-h4 text-center">@I18N[I18NKeys.Page.Register]</h1>

        <!-- Form -->
        <form hx-post="@AppRoutes.Auth.Register"
              hx-target="closest .card-body"
              hx-swap="innerHTML"
              hx-indicator="#register-spinner"
              class="space-y-4"
              x-data="{ showPassword: false, showConfirm: false, role: '@AppConstants.Roles.Buyer' }">
          @Html.AntiForgeryToken()

          <!-- Full name -->
          <partial name="@SharedViewPaths.TextField" view-data='@(new ViewDataDictionary(ViewData) {
              ["Label"]       = I18N[I18NKeys.Label.FullName],
              ["Name"]        = "FullName",
              ["Value"]       = "",
              ["Placeholder"] = I18N[I18NKeys.Label.FullNamePlaceholder],
              ["MaxLength"]   = FieldLimits.InlineStandard.MaxLength,
              ["Required"]    = "true"
          })'/>

          <!-- Email -->
          <partial name="@SharedViewPaths.EmailField" view-data='@(new ViewDataDictionary(ViewData) {
              ["Label"]    = I18N[I18NKeys.Label.Email],
              ["Name"]     = "Email",
              ["Value"]    = "",
              ["Required"] = "true"
          })'/>

          <!-- Password -->
          <div>
            <label for="password" class="form-label">@I18N[I18NKeys.Label.Password]</label>
            <div class="relative">
              <input :type="showPassword ? 'text' : 'password'" id="password" name="Password"
                     placeholder="@I18N[I18NKeys.Label.PasswordMinLength]" class="form-input pr-11" required/>
              <button type="button" @@click="showPassword = !showPassword"
                      class="absolute right-3 top-1/2 -translate-y-1/2 text-ink-400 hover:text-ink-600 transition-colors"
                      aria-label="@I18N[I18NKeys.Text.TogglePassword]">
                <svg x-show="!showPassword" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                </svg>
                <svg x-show="showPassword" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Confirm Password -->
          <div>
            <label for="confirmPassword" class="form-label">@I18N[I18NKeys.Label.ConfirmPassword]</label>
            <div class="relative">
              <input :type="showConfirm ? 'text' : 'password'" id="confirmPassword" name="ConfirmPassword"
                     placeholder="@I18N[I18NKeys.Label.ConfirmPasswordPlaceholder]" class="form-input pr-11" required/>
              <button type="button" @@click="showConfirm = !showConfirm"
                      class="absolute right-3 top-1/2 -translate-y-1/2 text-ink-400 hover:text-ink-600 transition-colors"
                      aria-label="@I18N[I18NKeys.Text.TogglePassword]">
                <svg x-show="!showConfirm" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                </svg>
                <svg x-show="showConfirm" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Role selection -->
          <div>
            <label class="form-label">@I18N[I18NKeys.Label.YouAre]</label>
            <input type="hidden" name="Role" :value="role"/>
            <div class="grid grid-cols-2 gap-3">
              <!-- Buyer card -->
              <button type="button" @@click="role = '@AppConstants.Roles.Buyer'"
                      :class="role === '@AppConstants.Roles.Buyer'
                ? 'border-ink-700 bg-ink-700/5 ring-2 ring-ink-700/20'
                : 'border-ink-200 hover:border-ink-300'"
                      class="flex flex-col items-center gap-2 rounded-2xl border p-4 transition-all duration-150 cursor-pointer">
                <svg class="w-7 h-7 text-ink-500" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                </svg>
                <span class="text-sm font-semibold text-ink-700">@I18N[I18NKeys.Text.RoleBuyer]</span>
                <span class="text-xs text-ink-400">@I18N[I18NKeys.Text.RoleBuyerDesc]</span>
              </button>
              <!-- Seller card -->
              <button type="button" @@click="role = '@AppConstants.Roles.Seller'"
                      :class="role === '@AppConstants.Roles.Seller'
                ? 'border-ink-700 bg-ink-700/5 ring-2 ring-ink-700/20'
                : 'border-ink-200 hover:border-ink-300'"
                      class="flex flex-col items-center gap-2 rounded-2xl border p-4 transition-all duration-150 cursor-pointer">
                <svg class="w-7 h-7 text-ink-500" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/>
                </svg>
                <span class="text-sm font-semibold text-ink-700">@I18N[I18NKeys.Text.RoleSeller]</span>
                <span class="text-xs text-ink-400">@I18N[I18NKeys.Text.RoleSellerDesc]</span>
              </button>
            </div>
          </div>

          <!-- Terms -->
          <label class="flex items-start gap-2.5 cursor-pointer">
            <input type="checkbox" name="AgreeTerms"
                   class="w-4 h-4 mt-0.5 rounded border-ink-300 text-ink-700 focus:ring-ink-200 transition" required/>
            <span class="text-sm text-ink-600">
              @I18N[I18NKeys.Text.AgreeTerms]
              <a href="#" class="font-semibold underline underline-offset-2 hover:text-ink-700 transition-colors">
                @I18N[I18NKeys.Link.TermsOfService]
              </a>
              @I18N[I18NKeys.Text.And]
              <a href="#" class="font-semibold underline underline-offset-2 hover:text-ink-700 transition-colors">
                @I18N[I18NKeys.Link.PrivacyPolicy]
              </a>
            </span>
          </label>

          <!-- Submit -->
          <button type="submit" class="btn-primary w-full">
            <span id="register-spinner" class="htmx-indicator">
              <svg class="animate-spin h-4 w-4 inline mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </span>
            @I18N[I18NKeys.Button.Register]
          </button>
        </form>

        <!-- Login link -->
        <p class="text-sm text-ink-500 text-center">
          @I18N[I18NKeys.Text.HasAccount]
          <a href="@AppRoutes.Auth.Login"
             class="font-semibold text-ink-700 hover:text-accent-600 underline underline-offset-2 transition-colors">
            @I18N[I18NKeys.Link.Login]
          </a>
        </p>

      </div>
    </div>
  </div>
</section>
