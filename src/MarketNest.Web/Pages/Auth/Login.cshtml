@page "/auth/login"
@model MarketNest.Web.Pages.Auth.LoginModel
@{
  ViewData["Title"] = I18N[I18NKeys.Page.Login];
}

<section class="flex items-center justify-center min-h-[calc(100vh-200px)] py-12 px-4">
  <div class="w-full max-w-md">
    <div class="card">
      <div class="card-body space-y-6">

        <!-- Logo -->
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ink-700 flex items-center justify-center">
            <span class="text-accent-400 font-bold text-lg italic" style="font-family:'Fraunces',serif">m</span>
          </div>
          <span class="text-lg font-semibold text-ink-700 tracking-tight">@AppConstants.AppName</span>
        </div>

        <!-- Heading -->
        <h1 class="mn-h4 text-center">@I18N[I18NKeys.Page.Login]</h1>

        <!-- Form -->
        <form hx-post="@AppRoutes.Auth.Login"
              hx-target="closest .card-body"
              hx-swap="innerHTML"
              hx-indicator="#login-spinner"
              class="space-y-4"
              x-data="{ showPassword: false }">
          @Html.AntiForgeryToken()

          <!-- Email -->
          <partial name="@SharedViewPaths.EmailField" view-data='@(new ViewDataDictionary(ViewData) {
              ["Label"]    = I18N[I18NKeys.Label.Email],
              ["Name"]     = "Email",
              ["Value"]    = "",
              ["Required"] = "true"
          })'/>

          <!-- Password -->
          <div>
            <label for="password" class="form-label">@I18N[I18NKeys.Label.Password]</label>
            <div class="relative">
              <input :type="showPassword ? 'text' : 'password'" id="password" name="Password"
                     placeholder="@I18N[I18NKeys.Label.PasswordPlaceholder]" class="form-input pr-11" required/>
              <button type="button" @@click="showPassword = !showPassword"
                      class="absolute right-3 top-1/2 -translate-y-1/2 text-ink-400 hover:text-ink-600 transition-colors"
                      aria-label="@I18N[I18NKeys.Text.TogglePassword]">
                <!-- Eye open -->
                <svg x-show="!showPassword" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                </svg>
                <!-- Eye closed -->
                <svg x-show="showPassword" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
                     viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Remember + Forgot -->
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="RememberMe"
                     class="w-4 h-4 rounded border-ink-300 text-ink-700 focus:ring-ink-200 transition"/>
              <span class="text-sm text-ink-600">@I18N[I18NKeys.Text.RememberMe]</span>
            </label>
            <a href="@AppRoutes.Auth.ForgotPassword"
               class="text-sm font-medium text-ink-600 hover:text-ink-700 underline underline-offset-2 transition-colors">
              @I18N[I18NKeys.Link.ForgotPassword]
            </a>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-primary w-full">
            <span id="login-spinner" class="htmx-indicator">
              <svg class="animate-spin h-4 w-4 inline mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </span>
            @I18N[I18NKeys.Button.Login]
          </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-3">
          <div class="flex-1 border-t border-ink-100/60"></div>
          <span class="text-xs text-ink-400 font-medium">@I18N[I18NKeys.Text.Or]</span>
          <div class="flex-1 border-t border-ink-100/60"></div>
        </div>

        <!-- Social login buttons -->
        <div class="flex flex-col gap-3">
          <button type="button" disabled class="btn-ghost w-full opacity-60 cursor-not-allowed">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            @I18N[I18NKeys.Button.LoginGoogle]
          </button>
          <button type="button" disabled class="btn-ghost w-full opacity-60 cursor-not-allowed">
            <svg class="w-5 h-5" fill="#1877F2" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            @I18N[I18NKeys.Button.LoginFacebook]
          </button>
        </div>

        <!-- Register link -->
        <p class="text-sm text-ink-500 text-center">
          @I18N[I18NKeys.Text.NoAccount]
          <a href="@AppRoutes.Auth.Register"
             class="font-semibold text-ink-700 hover:text-accent-600 underline underline-offset-2 transition-colors">
            @I18N[I18NKeys.Link.RegisterNow]
          </a>
        </p>

      </div>
    </div>
  </div>
</section>
