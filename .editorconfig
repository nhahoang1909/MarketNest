# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4

# CA1848: Use LoggerMessage delegates — disabled project-wide.
# [LoggerMessage] source-gen is only worthwhile on hot paths (called millions of times).
# Startup, infrastructure, and command-handler logging does not warrant the verbosity.
dotnet_diagnostic.CA1848.severity = none
# CA1727: Log message template parameters should be pascal case — too pedantic for this project.
dotnet_diagnostic.CA1727.severity = none
# CA1716: Identifiers should not match keywords — only relevant for multi-language public libraries.
dotnet_diagnostic.CA1716.severity = none

# Allow flat layer-level namespaces (folder-per-feature is allowed).
# Some IDEs or analyzers emit a diagnostic when namespace does not match folder path.
# This project intentionally uses layer-level namespaces (e.g., MarketNest.Admin.Application)
# irrespective of deeper folder organization (Modules/Account/Commands). Suppress common
# namespace-folder mismatch diagnostics here. If your IDE does not recognize these IDs,
# you may need to adjust your local analyzer settings.
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.IDE0079.severity = none
dotnet_diagnostic.SA1200.severity = none

# C# code style
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Use 'var' when type is apparent
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Prefer expression body
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors = false:suggestion

# Prefer pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Naming conventions
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.camel_case_underscore.capitalization = camel_case
dotnet_naming_style.camel_case_underscore.required_prefix = _

[*.{json,yml,yaml}]
indent_size = 2

[*.{cshtml,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile*]
indent_size = 4
