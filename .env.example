# ──────────────────────────────────────────────────────────
# MarketNest — Local Development Secrets
# ⚠️  Copy this file to .env and fill in real values:
#     cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── ASP.NET Core ──────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=marketnest
POSTGRES_USER=mn
POSTGRES_PASSWORD=<your-postgres-password>

# ── Connection Strings (app) ─────────────────────────────
CONNECTION_STRINGS__DEFAULTCONNECTION=Host=postgres;Database=marketnest;Username=mn;Password=<your-postgres-password>
# Leave ReadConnection empty to fall back to DefaultConnection (Phase 1).
# Phase 2: set this to a PostgreSQL read-replica to route all ReadDbContext queries there.
CONNECTION_STRINGS__READCONNECTION=

# ── Redis ─────────────────────────────────────────────────
REDIS_CONNECTION_STRING=redis:6379

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=mn
RABBITMQ_DEFAULT_PASS=<your-rabbitmq-password>
RABBITMQ_CONNECTION_STRING=amqp://mn:<your-rabbitmq-password>@rabbitmq:5672

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=<generate-a-random-string-at-least-32-chars>
JWT_ISSUER=MarketNest
JWT_AUDIENCE=MarketNest
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ── Seq (Logging) ────────────────────────────────────────
SEQ_SERVER_URL=http://seq:80

# ── MailHog (Dev SMTP) ───────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025

# ── Image Tag (Production) ───────────────────────────────
TAG=latest
